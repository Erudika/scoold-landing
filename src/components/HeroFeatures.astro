---
import { features_overview } from '../data/site-data.json';

const icons: Record<string, string> = {
  search: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>`,
  shield: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  star: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>`,
  lock: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>`,
  zap: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  users: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>`,
};
---

<section class="bg-white section-padding">
  <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <!-- Section header -->
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <span class="section-label">{features_overview.badge}</span>
      <h2 class="mb-4 font-extrabold text-slate-900 text-4xl lg:text-5xl tracking-tight">
        {features_overview.title}<br/>
        <span class="text-brand-600">{features_overview.title_highlight}</span>
      </h2>
      <p class="text-slate-700 text-lg leading-relaxed">
        {features_overview.subtitle}
      </p>
    </div>

    <!-- Feature grid -->
    <div class="gap-6 grid sm:grid-cols-2 lg:grid-cols-3">
      {features_overview.items.map((feature, i) => (
        <div class="group bg-white hover:shadow-brand-50 hover:shadow-lg p-6 border border-slate-300 hover:border-brand-200 rounded-2xl transition-all duration-300">
          <!-- Icon -->
          <div class="flex justify-center items-center bg-brand-50 group-hover:bg-brand-100 mb-4 rounded-xl w-11 h-11 transition-colors duration-300">
            <svg
              class="w-5 h-5 text-brand-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              set:html={icons[feature.icon] ?? icons.zap}
            />
          </div>
          <!-- Title -->
          <h3 class="mb-2 font-semibold text-slate-900 text-base">
            {feature.title}
          </h3>
          <!-- Description -->
          <p class="text-slate-700 text-sm leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>

    <!-- View all features link -->
    <div class="mt-10 text-center">
      <a
        href={features_overview.view_all_href}
        class="group inline-flex items-center gap-2 font-semibold text-brand-600 hover:text-brand-700 text-sm transition-colors"
      >
        {features_overview.view_all_label}
        &rarr;
      </a>
    </div>
  </div>
</section>
