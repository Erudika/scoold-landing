---
import { cta } from '../data/site-data.json';
---

<section class="bg-white section-padding">
  <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="relative bg-slate-900 px-8 py-16 rounded-3xl overflow-hidden text-center">
      <!-- Background decoration -->
      <div class="absolute inset-0 bg-dot-grid opacity-10 pointer-events-none"></div>
      <div class="top-0 left-1/2 absolute bg-brand-600 opacity-20 blur-3xl w-96 h-48 -translate-x-1/2 pointer-events-none"></div>

      <div class="relative">
        <h2 class="mx-auto mb-4 max-w-2xl font-extrabold text-white text-3xl sm:text-4xl lg:text-5xl tracking-tight">
          {cta.title}
        </h2>
        <p class="mx-auto mb-8 max-w-xl text-slate-600 text-lg leading-relaxed">
          {cta.subtitle}
        </p>
        <div class="flex sm:flex-row flex-col justify-center gap-4">
          <a
            href={cta.primary.href}
            class="inline-flex justify-center items-center gap-2 bg-brand-600 hover:bg-brand-500 px-7 py-3.5 rounded-xl font-semibold text-white text-sm transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            {cta.primary.label}
          </a>
          <a
            href={cta.secondary.href}
            class="inline-flex justify-center items-center gap-2 bg-white/10 hover:bg-white/20 px-7 py-3.5 border border-white/20 rounded-xl font-semibold text-white text-sm transition-all duration-200"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {cta.secondary.label}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
