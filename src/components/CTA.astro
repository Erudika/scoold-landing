---
import { cta, nav } from '../data/site-data.json';
---

<section class="bg-white section-padding">
  <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="relative bg-slate-900 px-8 py-16 rounded-3xl overflow-hidden text-center">
      <!-- Background decoration -->
      <div class="absolute inset-0 bg-dot-grid opacity-10 pointer-events-none"></div>
      <div class="top-0 left-1/2 absolute bg-brand-600 opacity-20 blur-3xl w-96 h-48 -translate-x-1/2 pointer-events-none"></div>

      <div class="relative">
        <h2 class="mx-auto mb-2 max-w-2xl font-extrabold text-white text-3xl sm:text-4xl lg:text-5xl tracking-tight">
          <span class="">
            {cta.title}
            <span class="min-h-15 text-rotate">
              <span>
                {nav.solutions.map((solution) => (
                  <span class="w-full">{solution.label}?</span>
                ))}
              </span>
            </span>
          </span>
        </h2>
        <p class="mx-auto mb-8 max-w-xl text-slate-200 text-lg leading-relaxed">
          {cta.subtitle}
        </p>
        <div class="flex sm:flex-row flex-col justify-center gap-4">
          <a
            href={cta.primary.href}
            class="inline-flex justify-center items-center gap-2 bg-brand-600 hover:bg-brand-500 px-7 py-3.5 rounded-xl font-semibold text-white transition-all duration-200"
          >
            <!-- <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
            </svg> -->
            {cta.primary.label}
          </a>
          <a
            href={cta.secondary.href}
            class="inline-flex justify-center items-center gap-2 bg-white/10 hover:bg-white/20 px-7 py-3.5 border border-white/20 rounded-xl font-semibold text-white transition-all duration-200"
          >
            <!-- <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg> -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
            </svg>
            {cta.secondary.label}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
