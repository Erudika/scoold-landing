---
import { pricing, site } from '../data/site-data.json';
---

<section class="bg-slate-50 section-padding" id="pricing">
  <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <!-- Section header -->
    <!-- <div class="mx-auto mb-16 max-w-2xl text-center">
      <span class="section-label">{pricing.badge}</span>
      <h2 class="mb-4 font-extrabold text-slate-900 text-4xl lg:text-5xl tracking-tight">
        {pricing.title} <span class="text-brand-600">{pricing.title_highlight}</span>
      </h2>
      <p class="text-slate-700 text-lg leading-relaxed">
        {pricing.subtitle}
      </p>
    </div> -->

    <!-- Pricing cards -->
    <div class="gap-6 lg:gap-8 grid md:grid-cols-3 mx-auto max-w-5xl">
      {pricing.plans.map((plan) => (
        <div
          class:list={[
            'relative rounded-2xl p-7 flex flex-col',
            plan.popular
              ? 'bg-slate-900 text-white shadow-2xl shadow-slate-900/30 ring-1 ring-slate-800'
              : 'bg-white border border-slate-200 shadow-sm',
          ]}
        >
          {/* Popular badge */}
          {plan.popular && plan.badge && (
            <div class="-top-3.5 left-1/2 absolute -translate-x-1/2">
              <span class="inline-block bg-brand-600 px-3 py-1 rounded-full font-bold text-white text-xs uppercase tracking-wider">
                {plan.badge}
              </span>
            </div>
          )}

          {/* Plan name */}
          <div class="mb-5">
            <h3 class:list={['text-lg font-bold mb-1', plan.popular ? 'text-white' : 'text-slate-900']}>
              {plan.name}
            </h3>
            <p class:list={['text-sm leading-relaxed', plan.popular ? 'text-slate-300' : 'text-slate-700']}>
              {plan.description}
            </p>
          </div>

          {/* Price */}
          <div class="mb-6">
            <div class:list={['text-4xl font-extrabold tracking-tight', plan.popular ? 'text-white' : 'text-slate-900']}>
              {plan.price.
                          replace("{pricePro}", site.priceSign + site.pricePro).
                          replace("{priceProPlus}", site.priceSign + site.priceProPlus)}
            </div>
            <div class:list={['text-sm font-medium mt-0.5', plan.popular ? 'text-slate-300' : 'text-slate-600']}>
              {plan.price_note}
            </div>
          </div>

          {/* CTA button */}
          <a
            href={plan.cta_href}
            class:list={[
              'block text-center px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-200 mb-6',
              plan.popular
                ? 'bg-brand-600 text-white hover:bg-brand-500'
                : plan.cta_style === 'outline'
                  ? 'border border-slate-200 text-slate-700 hover:border-slate-300 hover:bg-slate-50'
                  : 'bg-slate-900 text-white hover:bg-slate-700',
            ]}
            {...(plan.cta_href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {plan.cta_label}
          </a>

          {/* Features list */}
          <ul class="flex-1 space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg
                  class:list={['w-4 h-4 shrink-0 mt-0.5', plan.popular ? 'text-brand-100' : 'text-brand-500']}
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                <span class:list={['text-sm', plan.popular ? 'text-slate-100' : 'text-slate-600']}>
                  {feature}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    
    <div class="text-center">
      <p class="mt-10 px-40 text-md text-slate-600 text-center">
        {pricing.note}
      </p>
    </div>
  </div>
</section>
