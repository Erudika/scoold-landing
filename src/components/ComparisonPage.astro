---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from './CTA.astro';
import { site, ui, features_page } from '../data/site-data.json';
import { Image } from 'astro:assets';
import scooldLogo from '../images/logosq.svg';
import herobg from '../images/herobg.svg';

interface Props {
  title: string;
  subtitle: string;
  slug: string;
  description: string;
  hero_badge: string;
  intro: string[];
  pdf?: string;
  table_headers: string[];
  rows: (string | boolean)[][];
}
const logoSize = 100;
const { title, subtitle, slug, description, hero_badge, intro, table_headers, rows, pdf } = Astro.props;
---

<BaseLayout title={`${site.title} vs ${title} Comparison`} description={description}>
  <!-- Hero -->
  <section class="relative bg-white border-slate-100 border-b animate-fade-in section-padding" style={`background-image: url(${herobg.src});`}>
    <!-- Gradient fade edges -->
    <div class="absolute inset-0 bg-linear-to-b from-white via-transparent to-white pointer-events-none"></div>

    <div class="relative mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl text-center">
      <span class="section-label">{hero_badge}</span>
      <h1 class="mb-5 font-extrabold text-slate-900 text-5xl lg:text-6xl tracking-tight">
        {site.title} <span class="text-brand-500">vs</span> {title}
      </h1>

      <div class="flex justify-center items-center py-10">
        <div class="pt-1">
          <Image src={scooldLogo} 
            width={logoSize} 
            height={logoSize} 
            alt="Scoold Logo" 
            class="bg-white p-1 border border-neutral-300 rounded-2xl" 
            loading="eager"
          />
        </div>
        <span class="px-7 text-neutral-400 text-8xl">⚔</span>
        <!-- <svg class="inline-block mx-7 w-24 h-24 text-neutral-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
        </svg> -->
        <div class="pb-1">
          <Image src={import(`../images/${slug}.svg`)} 
            width={logoSize} 
            height={logoSize} 
            alt={`${slug} Logo`} 
            class="bg-white p-4 border border-neutral-300 rounded-2xl" 
            loading="eager"
          />
        </div>
      </div>

      <p class="text-slate-800 text-xl leading-relaxed">{subtitle}</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="bg-slate-50 py-14 animate-fade-in">
    <div class="text-center">
      <span class="mb-8 font-bold text-brand-600 text-sm text-center uppercase tracking-widest section-label">{features_page.comparison.title2}</span>
    </div>
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      {intro.map((text) => (
        <p class="py-2 text-slate-800 text-lg text-justify leading-relaxed">{text}</p>
      ))}
    </div>
  </section>

  <!-- Comparison table -->
  <section class="bg-white section-padding">
    <div class="text-center">
      <span class="mb-8 font-bold text-brand-600 text-sm text-center uppercase tracking-widest section-label">{features_page.comparison.hero_badge}</span>
    </div>
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="overflow-x-auto">
        <table class="border border-slate-200 rounded-2xl w-full overflow-hidden text-sm">
          <thead>
            <tr class="bg-slate-50">
              {table_headers.map((header, i) => (
                <th
                  class:list={[
                    'py-4 font-semibold text-sm',
                    i === 0 ? 'text-left pl-6 w-1/4 text-slate-600' : 'text-center px-6',
                    i === 2 ? 'text-brand-600 bg-brand-50' : '',
                  ]}
                >
                  {header}
                </th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            {rows.map((row) => (
              <tr class="hover:bg-slate-50 transition-colors">
                {row.map((cell, i) => (
                  <td
                    class:list={[
                      'py-4',
                      i === 0 ? 'pl-6 font-medium text-slate-700' : 'text-center px-6',
                      i === 2 ? 'bg-brand-50/30' : '',
                    ]}
                  >
                    {typeof cell === 'boolean' ? (
                      cell ? (
                        <div class="flex justify-center">
                          <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                          </svg>
                        </div>
                      ) : (
                        <div class="flex justify-center">
                          <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                          </svg>
                        </div>
                      )
                    ) : (
                      <span class:list={[i === 2 ? 'text-brand-700 font-medium' : 'text-slate-600']}>{cell.replace("{price}", site.priceSign + site.pricePro)}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-8 text-center">
        <a
          href={ui.comparison_page.cta_href}
          class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-700 px-7 py-3.5 rounded-xl font-semibold text-md text-white transition-colors"
        >
          {ui.comparison_page.cta_label}
          &rarr;
        </a>
        {pdf && 
          <a class="relative gap-2 bg-white hover:bg-slate-50 mx-2 px-6 py-3.5 border border-slate-200 hover:border-slate-300 rounded-xl font-semibold text-md text-slate-700 transition-all duration-200" href={pdf} download>
            <svg class="top-2 left-3 absolute mr-8 w-8" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <rect x="0" fill="none" width="20" height="20"></rect> <g> <style>.st0{fill-rule:evenodd;clip-rule:evenodd;}</style> <path d="M5.8 14H5v1h.8c.3 0 .5-.2.5-.5s-.2-.5-.5-.5zM11 2H3v16h13V7l-5-5zM7.2 14.6c0 .8-.6 1.4-1.4 1.4H5v1H4v-4h1.8c.8 0 1.4.6 1.4 1.4v.2zm4.1.5c0 1-.8 1.9-1.9 1.9H8v-4h1.4c1 0 1.9.8 1.9 1.9v.2zM15 14h-2v1h1.5v1H13v1h-1v-4h3v1zm0-2H4V3h7v4h4v5zm-5.6 2H9v2h.4c.6 0 1-.4 1-1s-.5-1-1-1z"></path> </g> </g></svg>
            <span class="pl-7">Download Full Comparison PDF</span>
          </a>
        }
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
