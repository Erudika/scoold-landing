---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from './CTA.astro';
import { site, ui } from '../data/site-data.json';

interface Props {
  title: string;
  subtitle: string;
  hero_badge: string;
  intro: string;
  table_headers: string[];
  rows: (string | boolean)[][];
  metaDescription?: string;
}

const { title, subtitle, hero_badge, intro, table_headers, rows, metaDescription } = Astro.props;
---

<BaseLayout title={title} description={metaDescription ?? subtitle}>
  <!-- Hero -->
  <section class="bg-white border-slate-100 border-b section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl text-center">
      <span class="section-label">{hero_badge}</span>
      <h1 class="mb-5 font-extrabold text-slate-900 text-5xl lg:text-6xl tracking-tight">
        {title}
      </h1>
      <p class="text-slate-700 text-xl leading-relaxed">{subtitle}</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="bg-slate-50 py-14">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <p class="text-slate-600 text-lg text-center leading-relaxed">{intro}</p>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="overflow-x-auto">
        <table class="border border-slate-200 rounded-2xl w-full overflow-hidden text-sm">
          <thead>
            <tr class="bg-slate-50">
              {table_headers.map((header, i) => (
                <th
                  class:list={[
                    'py-4 font-semibold text-sm',
                    i === 0 ? 'text-left pl-6 w-2/5 text-slate-600' : 'text-center px-6',
                    i === 1 ? 'text-brand-600 bg-brand-50' : '',
                  ]}
                >
                  {header}
                </th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {rows.map((row) => (
              <tr class="hover:bg-slate-50 transition-colors">
                {row.map((cell, i) => (
                  <td
                    class:list={[
                      'py-4',
                      i === 0 ? 'pl-6 font-medium text-slate-700' : 'text-center px-6',
                      i === 1 ? 'bg-brand-50/30' : '',
                    ]}
                  >
                    {typeof cell === 'boolean' ? (
                      cell ? (
                        <div class="flex justify-center">
                          <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                          </svg>
                        </div>
                      ) : (
                        <div class="flex justify-center">
                          <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                          </svg>
                        </div>
                      )
                    ) : (
                      <span class:list={[i === 1 ? 'text-brand-700 font-medium' : 'text-slate-600']}>{cell.replace("{price}", site.priceSign + site.pricePro)}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-8 text-center">
        <a
          href={ui.comparison_page.cta_href}
          class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-700 px-7 py-3.5 rounded-xl font-semibold text-white text-sm transition-colors"
        >
          {ui.comparison_page.cta_label}
          &rarr;
        </a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
