---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from './CTA.astro';

interface Feature {
  title: string;
  description: string;
}

interface Props {
  title: string;
  subtitle: string;
  hero_badge: string;
  description: string;
  features: Feature[];
  setup_steps: string[];
  metaDescription?: string;
}

const { title, subtitle, hero_badge, description, features, setup_steps, metaDescription } = Astro.props;
---

<BaseLayout title={title} description={metaDescription ?? subtitle}>
  <!-- Hero -->
  <section class="section-padding bg-white border-b border-slate-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="section-label">{hero_badge}</span>
      <h1 class="text-5xl lg:text-6xl font-extrabold text-slate-900 tracking-tight mb-5">
        {title}
      </h1>
      <p class="text-xl text-slate-500 leading-relaxed mb-4">{subtitle}</p>
      <p class="text-base text-slate-400 leading-relaxed max-w-2xl mx-auto">{description}</p>
    </div>
  </section>

  <!-- Integration features -->
  <section class="section-padding bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-sm font-bold uppercase tracking-widest text-brand-600 mb-8 text-center">Integration highlights</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        {features.map((feature) => (
          <div class="bg-white border border-slate-100 rounded-2xl p-6">
            <div class="w-8 h-8 bg-brand-50 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-900 mb-2">{feature.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Setup steps -->
  <section class="section-padding bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-slate-900 mb-8">How to set it up</h2>
      <ol class="space-y-4">
        {setup_steps.map((step, i) => (
          <li class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-brand-600 text-white font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">
              {i + 1}
            </div>
            <div class="pt-1">
              <p class="text-sm text-slate-600 leading-relaxed">{step}</p>
            </div>
          </li>
        ))}
      </ol>
      <div class="mt-8 p-5 bg-brand-50 border border-brand-100 rounded-xl">
        <p class="text-sm text-brand-800">
          <strong>Need detailed setup instructions?</strong>{' '}
          <a href="/documentation" class="font-medium underline hover:no-underline">Read the documentation →</a>
        </p>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
