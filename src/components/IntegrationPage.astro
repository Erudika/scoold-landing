---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from './CTA.astro';
import { ui } from '../data/site-data.json';

interface Feature {
  title: string;
  description: string;
}

interface Props {
  title: string;
  subtitle: string;
  hero_badge: string;
  description: string;
  features: Feature[];
  setup_steps: string[];
  metaDescription?: string;
}

const { title, subtitle, hero_badge, description, features, setup_steps, metaDescription } = Astro.props;
---

<BaseLayout title={title} description={metaDescription ?? subtitle}>
  <!-- Hero -->
  <section class="bg-white border-slate-100 border-b section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl text-center">
      <span class="section-label">{hero_badge}</span>
      <h1 class="mb-5 font-extrabold text-slate-900 text-5xl lg:text-6xl tracking-tight">
        {title}
      </h1>
      <p class="mb-4 text-slate-700 text-xl leading-relaxed">{subtitle}</p>
      <p class="mx-auto max-w-2xl text-slate-600 text-base leading-relaxed">{description}</p>
    </div>
  </section>

  <!-- Integration features -->
  <section class="bg-slate-50 section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="mb-8 font-bold text-brand-600 text-sm text-center uppercase tracking-widest">{ui.integration_page.highlights_label}</h2>
      <div class="gap-6 grid sm:grid-cols-3">
        {features.map((feature) => (
          <div class="bg-white p-6 border border-slate-100 rounded-2xl">
            <div class="flex justify-center items-center bg-brand-50 mb-3 rounded-lg w-8 h-8">
              <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <h3 class="mb-2 font-semibold text-slate-900">{feature.title}</h3>
            <p class="text-slate-700 text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Setup steps -->
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <h2 class="mb-8 font-bold text-slate-900 text-2xl">{ui.integration_page.setup_label}</h2>
      <ol class="space-y-4">
        {setup_steps.map((step, i) => (
          <li class="flex gap-4">
            <div class="flex justify-center items-center bg-brand-600 mt-0.5 rounded-full w-8 h-8 font-bold text-white text-sm shrink-0">
              {i + 1}
            </div>
            <div class="pt-1">
              <p class="text-slate-600 text-sm leading-relaxed">{step}</p>
            </div>
          </li>
        ))}
      </ol>
      <div class="bg-brand-50 mt-8 p-5 border border-brand-100 rounded-xl">
        <p class="text-brand-800 text-sm">
          <strong>{ui.integration_page.docs_cta_text}</strong>{' '}
          <a href={ui.integration_page.docs_href} class="font-medium underline hover:no-underline">{ui.integration_page.docs_link_label}</a>
        </p>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
