---
import { faq } from '../data/site-data.json';

interface Props {
  limit?: number;
}
const { limit } = Astro.props;
const items = limit ? faq.items.slice(0, limit) : faq.items;
---

<section class="bg-white section-padding" id="faq">
  <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
    <!-- Section header -->
    <div class="mb-14 text-center">
      <span class="section-label">{faq.badge}</span>
      <h2 class="mb-4 font-extrabold text-slate-900 text-4xl lg:text-5xl tracking-tight">
        {faq.title} <span class="text-brand-600">{faq.title_highlight}</span>
      </h2>
      <p class="text-slate-500 text-lg leading-relaxed">
        {faq.subtitle}
      </p>
    </div>

    <!-- Accordion -->
    <div class="space-y-3">
      {items.map((item, i) => (
        <div
          class="border border-slate-100 hover:border-slate-200 rounded-xl overflow-hidden transition-colors faq-item"
          id={`faq-${i}`}
        >
          <button
            class="flex justify-between items-start gap-4 px-5 py-4 w-full font-medium text-slate-800 hover:text-brand-600 text-left transition-colors faq-trigger"
            aria-expanded="false"
            aria-controls={`faq-body-${i}`}
          >
            <span class="text-sm sm:text-base">{item.q}</span>
            <svg
              class="mt-0.5 w-5 h-5 text-slate-400 transition-transform duration-200 faq-icon shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            class="hidden px-5 pb-5 faq-body"
            id={`faq-body-${i}`}
          >
            <p class="pt-4 border-slate-100 border-t text-slate-500 text-sm leading-relaxed">
              {item.a}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Support CTA -->
    <div class="bg-slate-50 mt-12 p-8 border border-slate-100 rounded-2xl text-center">
      <div class="flex justify-center items-center bg-brand-100 mx-auto mb-3 rounded-xl w-10 h-10">
        <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
      </div>
      <h3 class="mb-1.5 font-semibold text-slate-800 text-base">{faq.support_cta.title}</h3>
      <p class="mb-4 text-slate-500 text-sm">
        {faq.support_cta.subtitle}
      </p>
      <a
        href={faq.support_cta.cta_href}
        class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-700 px-5 py-2.5 rounded-xl font-semibold text-white text-sm transition-colors"
      >
        {faq.support_cta.cta_label}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const body = item?.querySelector('.faq-body');
      const icon = trigger.querySelector('.faq-icon');
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all others
      document.querySelectorAll('.faq-item').forEach((other) => {
        if (other !== item) {
          other.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
          other.querySelector('.faq-body')?.classList.add('hidden');
          other.querySelector('.faq-icon')?.classList.remove('rotate-180');
        }
      });

      // Toggle current
      trigger.setAttribute('aria-expanded', String(!isOpen));
      body?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
