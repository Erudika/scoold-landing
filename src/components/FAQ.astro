---
import { faq } from '../data/site-data.json';

interface Props {
  limit?: number;
}
const { limit } = Astro.props;
const items = limit ? faq.items.slice(0, limit) : faq.items;
const faqClasses = "mb-4 font-extrabold text-slate-900 text-4xl lg:text-5xl tracking-tight";
const faqTitle = `${faq.title} <span class="text-brand-600">${faq.title_highlight}</span>`;
---

<section class="bg-white section-padding" id="faq">
  <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
    <!-- Section header -->
    <div class="mb-14 text-center">
      <span class="section-label">{faq.badge}</span>
      {Astro.originPathname === '/' ? 
        <h2 class:list={faqClasses} set:html={faqTitle}></h2> :
        <h1 class:list={faqClasses} set:html={faqTitle}></h1>
      }
      <p class="text-slate-700 text-lg leading-relaxed">
        {faq.subtitle}
      </p>
    </div>

    <!-- Accordion -->
    <div class="space-y-3">
      {items.map((item, i) => (
        <div tabindex="0" class="collapse collapse-arrow bg-base-100 border border-base-300 hover:border-slate-500">
          <div class="collapse-title font-semibold">{item.q}</div>
          <div class="collapse-content text-sm">{item.a}</div>
        </div>
      ))}
    </div>

    <!-- Support CTA -->
    <div class="bg-slate-50 mt-12 p-8 border border-slate-100 rounded-2xl text-center">
      <div class="flex justify-center items-center bg-brand-100 mx-auto mb-3 rounded-xl w-10 h-10">
        <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
      </div>
      <h3 class="mb-1.5 font-semibold text-slate-800 text-base">{faq.support_cta.title}</h3>
      <p class="mb-4 text-slate-700 text-sm">
        {faq.support_cta.subtitle}
      </p>
      <a
        href={faq.support_cta.cta_href}
        class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-700 px-5 py-2.5 rounded-xl font-semibold text-white text-sm transition-colors"
      >
        {faq.support_cta.cta_label}
        &rarr;
      </a>
    </div>
  </div>
</section>
