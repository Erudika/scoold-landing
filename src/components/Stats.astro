---
import { stats } from '../data/site-data.json';
---

<section class="bg-slate-50 border-slate-100 border-y animate-fade-in">
  <div class="mx-auto px-4 sm:px-6 lg:px-8 py-12 max-w-7xl">
    <div class="gap-8 md:gap-0 grid grid-cols-2 md:grid-cols-4 md:divide-x md:divide-slate-200">
      {stats.map((stat) => (
        <div class="md:px-8 text-center">
          <div class="mb-1 font-extrabold text-slate-900 text-3xl lg:text-4xl">
            {stat.value}
          </div>
          <div class="font-medium text-slate-700 text-sm">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
