---
import siteData from '../data/site-data.json';

const { pricing } = siteData;
---

<section class="section-padding bg-slate-50" id="pricing">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="section-label">{pricing.badge}</span>
      <h2 class="text-4xl lg:text-5xl font-extrabold text-slate-900 tracking-tight mb-4">
        {pricing.title} <span class="text-brand-600">{pricing.title_highlight}</span>
      </h2>
      <p class="text-lg text-slate-500 leading-relaxed">
        {pricing.subtitle}
      </p>
    </div>

    <!-- Pricing cards -->
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto">
      {pricing.plans.map((plan) => (
        <div
          class:list={[
            'relative rounded-2xl p-7 flex flex-col',
            plan.popular
              ? 'bg-slate-900 text-white shadow-2xl shadow-slate-900/30 ring-1 ring-slate-800'
              : 'bg-white border border-slate-200 shadow-sm',
          ]}
        >
          {/* Popular badge */}
          {plan.popular && plan.badge && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="inline-block px-3 py-1 bg-brand-600 text-white text-xs font-bold rounded-full tracking-wider uppercase">
                {plan.badge}
              </span>
            </div>
          )}

          {/* Plan name */}
          <div class="mb-5">
            <h3 class:list={['text-lg font-bold mb-1', plan.popular ? 'text-white' : 'text-slate-900']}>
              {plan.name}
            </h3>
            <p class:list={['text-sm leading-relaxed', plan.popular ? 'text-slate-400' : 'text-slate-500']}>
              {plan.description}
            </p>
          </div>

          {/* Price */}
          <div class="mb-6">
            <div class:list={['text-4xl font-extrabold tracking-tight', plan.popular ? 'text-white' : 'text-slate-900']}>
              {plan.price}
            </div>
            <div class:list={['text-sm font-medium mt-0.5', plan.popular ? 'text-slate-400' : 'text-slate-400']}>
              {plan.price_note}
            </div>
          </div>

          {/* CTA button */}
          <a
            href={plan.cta_href}
            class:list={[
              'block text-center px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-200 mb-6',
              plan.popular
                ? 'bg-brand-600 text-white hover:bg-brand-500'
                : plan.cta_style === 'outline'
                  ? 'border border-slate-200 text-slate-700 hover:border-slate-300 hover:bg-slate-50'
                  : 'bg-slate-900 text-white hover:bg-slate-700',
            ]}
            {...(plan.cta_href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {plan.cta_label}
          </a>

          {/* Features list */}
          <ul class="space-y-3 flex-1">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg
                  class:list={['w-4 h-4 flex-shrink-0 mt-0.5', plan.popular ? 'text-brand-400' : 'text-brand-500']}
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                <span class:list={['text-sm', plan.popular ? 'text-slate-300' : 'text-slate-600']}>
                  {feature}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    {/* Note */}
    <p class="text-center text-sm text-slate-400 mt-8">
      {pricing.note}
    </p>

    {/* Compare all features link */}
    <div class="text-center mt-4">
      <a
        href="/features"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-600 hover:text-brand-700 transition-colors"
      >
        Compare all features
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</section>
