---
import { nav } from '../data/site-data.json';
import scooldLogo from '../images/logo.svg';
import { Image } from 'astro:assets';
const currentPath = Astro.url.pathname;
const dropdownActivePaths: Record<string, string> = {
  solutions: '/solutions',
  comparisons: '/comparison',
  integrations: '/integration-with',
};
const isDropdownActive = (key: string) =>
  currentPath.startsWith(dropdownActivePaths[key] ?? '');


const icons: Record<string, string> = {
  search: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>`,
  shield: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  star: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>`,
  lock: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>`,
  zap: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  users: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  check: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />`,
  book: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>`,
  code: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>`,
  headset: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>`,
  question: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  issue: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286Zm0 13.036h.008v.008H12v-.008Z" />`,
  puzzle: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.39 48.39 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" />`
};
---

<header
  class="top-0 z-50 sticky bg-white/95 backdrop-blur-sm border-slate-200 border-b w-full"
  id="nav-header"
>
  <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <nav class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href={nav.logo.href} class="group flex items-center gap-2.5 shrink-0">
        <Image src={scooldLogo} alt="Scoold Logo" class="max-w-45" loading="eager"}/>
      </a>
      <!-- Desktop nav bar -->
      <div class="hidden md:flex items-center gap-1">
        <ul class="rounded-box menu menu-horizontal">
          <li class="text-lg">
            <a href={nav.links[0].href} aria-label={nav.links[0].label}>{nav.links[0].label}</a>
          </li>
          <li class="text-lg">
            <details>
              <summary>{nav.links[4].label}</summary>
              <ul class="bg-white/97 backdrop-blur-sm lg:-ml-50 border-slate-200 border-b rounded-box md:min-w-max text-lg menu xl:menu-horizontal lg:menu-horizontal">
                <li>
                  <span>{nav.links[1].label}</span>
                  <ul>
                  {nav.solutions.map((item) => (
                    <li>
                      <a href={item.href} aria-label={item.label}>
                        <svg
                          class="w-5 h-5 text-brand-600"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                          set:html={icons[item.icon] ?? icons.zap}
                        />
                        {item.label}</a>
                    </li>
                  ))}
                  </ul>
                </li>
                <li>
                  <span>{nav.links[2].label}</span>
                  <ul>
                  {nav.integrations.map((item) => (
                    <li>
                      <a href={item.href} aria-label={item.label}>
                        {item.icon ? 
                          <svg
                            class="w-5 h-5 text-brand-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            set:html={icons[item.icon]}
                            />
                          : 
                          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 256 256" class="fill-brand-600"><path d="M148.24,139.76a6,6,0,0,0-8.48,0L120,159.51,96.49,136l19.75-19.76a6,6,0,0,0-8.48-8.48L88,127.51,68.24,107.76a6,6,0,0,0-8.48,8.48L67.51,124,42.79,148.73a30,30,0,0,0,0,42.42l6.78,6.79L19.76,227.76a6,6,0,1,0,8.48,8.48l29.82-29.81,6.79,6.78a30,30,0,0,0,42.42,0L132,188.49l7.76,7.75a6,6,0,0,0,8.48-8.48L128.49,168l19.75-19.76A6,6,0,0,0,148.24,139.76Zm-49.45,65a18,18,0,0,1-25.46,0L51.27,182.67a18,18,0,0,1,0-25.46L76,132.49,123.51,180Zm137.45-185a6,6,0,0,0-8.48,0L197.94,49.57l-6.79-6.78a30,30,0,0,0-42.42,0L124,67.51l-7.76-7.75a6,6,0,0,0-8.48,8.48l80,80a6,6,0,0,0,8.48-8.48L188.49,132l24.72-24.73a30,30,0,0,0,0-42.42l-6.78-6.79,29.81-29.82A6,6,0,0,0,236.24,19.76Zm-31.51,79L180,123.51,132.49,76l24.72-24.73a18,18,0,0,1,25.46,0l22.06,22.06a18,18,0,0,1,0,25.46Z"></path></svg>
                        }
                        {item.label}</a>
                    </li>
                  ))}
                  </ul>
                </li>
                <li>
                  <span>{nav.links[3].label}</span>
                  <ul>
                  {nav.comparisons.map((item) => (
                    <li>
                      <a href={item.href} aria-label={item.label}>
                        <svg
                          class="w-5 h-5 text-brand-600"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                          set:html={icons[item.icon] ?? icons.zap}
                        />
                        {item.label}</a>
                    </li>
                  ))}
                  </ul>
                </li>
              </ul>
            </details>
          </li>
          <li class="text-lg">
            <a href={nav.links[5].href} aria-label={nav.links[5].label}>{nav.links[5].label}</a>
          </li>
          <li class="text-lg">
            <a href={nav.links[6].href} aria-label={nav.links[6].label}>{nav.links[6].label}</a>
          </li>
        </ul>
      </div>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center gap-3">
        <a
          href={nav.cta.href}
          class="inline-flex items-center gap-1.5 bg-slate-900 hover:bg-slate-700 px-4 py-2 rounded-lg font-semibold text-white text-sm transition-colors duration-150"
        >
          {nav.cta.label}
          &rarr;
        </a>
      </div>

      <!-- Mobile menu button -->
      <label class="md:hidden bg-transparent hover:bg-transparent rounded-lg transition-all animate-fade-in btn btn-circle swap swap-rotate">
        <!-- this hidden checkbox controls the state -->
        <input id="mobile-menu-btn" type="checkbox" />
        <svg
          class="fill-current swap-off"
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 512 512">
          <path d="M64,384H448V341.33H64Zm0-106.67H448V234.67H64ZM64,128v42.67H448V128Z" />
        </svg>
        <svg
          class="fill-current swap-on"
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 512 512">
          <polygon
            points="400 145.49 366.51 112 256 222.51 145.49 112 112 145.49 222.51 256 112 366.51 145.49 400 256 289.49 366.51 400 400 366.51 289.49 256 400 145.49" />
        </svg>
      </label>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-slate-100 border-t">
    <div class="space-y-1 mx-auto px-4 py-4 max-w-7xl">
      {nav.links.filter(l => !l.dropdown).map((link) => (
        <a
          href={link.href}
          aria-label={link.label}
          class="block hover:bg-slate-50 px-3 py-2.5 rounded-lg font-medium text-slate-700 hover:text-brand-600 text-sm transition-colors"
        >
          {link.label}
        </a>
      ))}
      <!-- Solutions -->
      <div class="mt-2 pt-1 pb-1 border-slate-100 border-t">
        <p class="px-3 py-1.5 font-semibold text-slate-600 text-xs uppercase tracking-wider">{nav.links[1].label}</p>
        <div class="ml-3">
          {nav.solutions.map((item) => (
            <a 
              href={item.href}
              aria-label={item.label}
              class="block hover:bg-slate-50 px-3 py-2.5 rounded-lg text-slate-700 hover:text-brand-600 text-sm transition-colors"
            >
              {item.label}
            </a>
          ))}
        </div>
      </div>
      
      <!-- Integrations -->
      <div class="mt-2 pt-1 pb-1 border-slate-100 border-t">
        <p class="px-3 py-1.5 font-semibold text-slate-600 text-xs uppercase tracking-wider">{nav.links[2].label}</p>
        <div class="ml-3">
          {nav.integrations.map((item) => (
            <a 
              href={item.href} 
              aria-label={item.label}
              class="block hover:bg-slate-50 px-3 py-2.5 rounded-lg text-slate-700 hover:text-brand-600 text-sm transition-colors"
            >
              {item.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Integrations -->
      <div class="mt-2 pt-1 pb-1 border-slate-100 border-t">
        <p class="px-3 py-1.5 font-semibold text-slate-600 text-xs uppercase tracking-wider">{nav.links[3].label}</p>
        <div class="ml-3">
          {nav.comparisons.map((item) => (
            <a 
              href={item.href}
              aria-label={item.label}
              class="block hover:bg-slate-50 px-3 py-2.5 rounded-lg text-slate-700 hover:text-brand-600 text-sm transition-colors"
            >
              {item.label}
            </a>
          ))}
        </div>
      </div>

      <div class="flex flex-col gap-2 pt-3 border-slate-100 border-t">
        <a
          href={nav.demo.href}
          aria-label={nav.demo.label_mobile}
          class="block hover:bg-slate-50 px-4 py-2.5 border border-slate-200 rounded-lg font-medium text-slate-700 text-sm text-center transition-colors"
          target="_blank"
        >
          {nav.demo.label_mobile}
        </a>
        <a
          href={nav.cta.href}
          class="block bg-slate-900 hover:bg-slate-700 px-4 py-2.5 rounded-lg font-semibold text-white text-sm text-center transition-colors"
        >
          {nav.cta.label}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Add shadow on scroll
  const header = document.getElementById('nav-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-sm');
    } else {
      header?.classList.remove('shadow-sm');
    }
  });
</script>
