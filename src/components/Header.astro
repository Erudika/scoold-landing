---
import { nav } from '../data/site-data.json';
import scooldLogo from '../images/logo.svg';
import { Image } from 'astro:assets';
const currentPath = Astro.url.pathname;
const dropdownActivePaths: Record<string, string> = {
  solutions: '/solutions',
  comparisons: '/comparison',
  integrations: '/integration-with',
};
const isDropdownActive = (key: string) =>
  currentPath.startsWith(dropdownActivePaths[key] ?? '');
---

<header
  class="top-0 z-50 sticky bg-white/95 backdrop-blur-sm border-slate-100 border-b w-full"
  id="nav-header"
>
  <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <nav class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href={nav.logo.href} class="group flex items-center gap-2.5 shrink-0">
        <Image src={scooldLogo} alt="Scoold Logo" class="max-w-45"/>
      </a>

      <!-- Desktop nav links -->
      <div class="hidden md:flex items-center gap-1">
        {nav.links.map((link) =>
          link.dropdown ? (
            <div class="group relative">
              <button
                class:list={[
                  'flex items-center gap-1 px-3 py-2 text-md font-medium rounded-lg transition-colors duration-150',
                  isDropdownActive(link.dropdown as string)
                    ? 'text-brand-600 bg-brand-50'
                    : 'text-slate-800 hover:text-slate-900 hover:bg-slate-50',
                ]}
              >
                {link.label}
                <svg class="opacity-50 w-3.5 h-3.5 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <!-- Dropdown -->
              <div class="invisible group-hover:visible top-full left-0 absolute bg-white opacity-0 group-hover:opacity-100 shadow-lg mt-1.5 py-2 border border-slate-100 rounded-xl w-64 transition-all duration-150 dropdown-menu">
                {link.dropdown === 'solutions' && nav.solutions_dropdown.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      'flex items-center gap-3 px-4 py-2.5 text-slate-800 hover:bg-slate-50 hover:text-brand-600 transition-colors',
                      currentPath === item.href ? 'text-brand-600 bg-brand-50' : '',
                    ]}
                  >
                    <span class="flex justify-center items-center w-5 h-5 text-brand-500">
                      {item.icon === 'book' && (
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                        </svg>
                      )}
                      {item.icon === 'users' && (
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                      )}
                      {item.icon === 'code' && (
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                        </svg>
                      )}
                      {item.icon === 'headset' && (
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                        </svg>
                      )}
                      {item.icon === 'question' && (
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                      )}
                      {item.icon === 'share' && (
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                        </svg>
                      )}
                    </span>
                    {item.label}
                  </a>
                ))}
                {link.dropdown === 'comparisons' && nav.comparisons_dropdown.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      'flex items-center px-4 py-2.5 text-slate-800 hover:bg-slate-50 hover:text-brand-600 transition-colors',
                      currentPath === item.href ? 'text-brand-600 bg-brand-50' : '',
                    ]}
                  >
                    {item.label}
                  </a>
                ))}
                {link.dropdown === 'integrations' && nav.integrations_dropdown.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      'flex items-center px-4 py-2.5 text-slate-800 hover:bg-slate-50 hover:text-brand-600 transition-colors',
                      currentPath === item.href ? 'text-brand-600 bg-brand-50' : '',
                    ]}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 font-medium rounded-lg transition-colors duration-150',
                currentPath === link.href || currentPath.startsWith(link.href + '/')
                  ? 'text-brand-600 bg-brand-50'
                  : 'text-slate-800 hover:text-slate-900 hover:bg-slate-50',
              ]}
            >
              {link.label}
            </a>
          )
        )}
      </div>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center gap-3">
        <a
          href={nav.demo.href}
          class="font-medium text-slate-600 hover:text-slate-900 text-sm transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          {nav.demo.label}
        </a>
        <a
          href={nav.cta.href}
          class="inline-flex items-center gap-1.5 bg-slate-900 hover:bg-slate-700 px-4 py-2 rounded-lg font-semibold text-white text-sm transition-colors duration-150"
        >
          {nav.cta.label}
          &rarr;
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex justify-center items-center hover:bg-slate-100 rounded-lg w-9 h-9 transition-colors"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" class="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="hidden w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-slate-100 border-t">
    <div class="space-y-1 mx-auto px-4 py-4 max-w-7xl">
      {nav.links.filter(l => !l.dropdown).map((link) => (
        <a
          href={link.href}
          class="block hover:bg-slate-50 px-3 py-2.5 rounded-lg font-medium text-slate-700 hover:text-brand-600 text-sm transition-colors"
        >
          {link.label}
        </a>
      ))}
      {nav.links.filter(l => l.dropdown).map((link) => (
        <div class="mt-2 pt-1 pb-1 border-slate-100 border-t">
          <p class="px-3 py-1.5 font-semibold text-slate-600 text-xs uppercase tracking-wider">{link.label}</p>
          {link.dropdown === 'solutions' && nav.solutions_dropdown.map((item) => (
            <a href={item.href} class="block hover:bg-slate-50 px-3 py-2.5 rounded-lg text-slate-700 hover:text-brand-600 text-sm transition-colors">
              {item.label}
            </a>
          ))}
          {link.dropdown === 'comparisons' && nav.comparisons_dropdown.map((item) => (
            <a href={item.href} class="block hover:bg-slate-50 px-3 py-2.5 rounded-lg text-slate-700 hover:text-brand-600 text-sm transition-colors">
              {item.label}
            </a>
          ))}
          {link.dropdown === 'integrations' && nav.integrations_dropdown.map((item) => (
            <a href={item.href} class="block hover:bg-slate-50 px-3 py-2.5 rounded-lg text-slate-700 hover:text-brand-600 text-sm transition-colors">
              {item.label}
            </a>
          ))}
        </div>
      ))}
      <div class="flex flex-col gap-2 pt-3 border-slate-100 border-t">
        <a
          href={nav.demo.href}
          class="block hover:bg-slate-50 px-4 py-2.5 border border-slate-200 rounded-lg font-medium text-slate-700 text-sm text-center transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          {nav.demo.label_mobile}
        </a>
        <a
          href={nav.cta.href}
          class="block bg-slate-900 hover:bg-slate-700 px-4 py-2.5 rounded-lg font-semibold text-white text-sm text-center transition-colors"
        >
          {nav.cta.label}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Add shadow on scroll
  const header = document.getElementById('nav-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-sm');
    } else {
      header?.classList.remove('shadow-sm');
    }
  });
</script>
