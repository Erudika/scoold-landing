---
import { footer, nav, imprint, legal_index } from '../data/site-data.json';
import { Image } from 'astro:assets';
import logoFooter from '../images/footer-logo.svg';
---

<footer class="bg-slate-900 text-slate-100">
  <!-- Main footer content -->
  <div class="mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8 max-w-7xl">
    <div class="gap-8 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-7 mb-12">
      <!-- Brand column -->
      <div class="lg:col-span-2">
        <a href="/" class="group flex items-center gap-2.5 mb-4">
          <Image src={logoFooter} alt="Scoold logo" width={160}/>
        </a>
        <p class="max-w-xs text-sm leading-relaxed">
          {footer.tagline}
        </p>
        <!-- Social links -->
        <div class="flex items-center gap-3 mt-5">
          {footer.social.map((s) => (
            <a
              href={s.href}
              class="flex justify-center items-center bg-slate-700 hover:bg-slate-600 rounded-lg w-11 h-11 text-slate-200 hover:text-white transition-colors"
              aria-label={s.name}
              target="_blank"
              title={s.name}
              rel="noopener noreferrer"
            >
              {s.icon === 'github' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
              )}
              {s.icon === 'twitter' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              {s.icon === 'docker' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M13.983 11.078h2.119a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.119a.185.185 0 00-.185.185v1.888c0 .102.083.185.185.185m-2.954-5.43h2.118a.186.186 0 00.186-.186V3.574a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.186m0 2.716h2.118a.187.187 0 00.186-.186V6.29a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.887c0 .102.082.185.185.186m-2.93 0h2.12a.186.186 0 00.184-.186V6.29a.185.185 0 00-.185-.185H8.1a.185.185 0 00-.185.185v1.887c0 .102.083.185.185.186m-2.964 0h2.119a.186.186 0 00.185-.186V6.29a.185.185 0 00-.185-.185H5.136a.186.186 0 00-.186.185v1.887c0 .102.084.185.186.186m5.893 2.715h2.118a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.185m-2.93 0h2.12a.185.185 0 00.184-.185V9.006a.185.185 0 00-.184-.186h-2.12a.185.185 0 00-.184.185v1.888c0 .102.083.185.185.185m-2.964 0h2.119a.185.185 0 00.185-.185V9.006a.185.185 0 00-.184-.186h-2.12a.186.186 0 00-.186.186v1.887c0 .102.084.185.186.185m-2.92 0h2.12a.186.186 0 00.184-.185V9.006a.185.185 0 00-.184-.186h-2.12a.185.185 0 00-.184.186v1.887c0 .102.082.185.185.185M23.763 9.89c-.065-.051-.672-.51-1.954-.51-.338.001-.676.03-1.01.087-.248-1.7-1.653-2.53-1.716-2.566l-.344-.199-.226.327c-.284.438-.49.922-.612 1.43-.23.97-.09 1.882.403 2.661-.595.332-1.55.413-1.744.42H.751a.751.751 0 00-.75.748 11.376 11.376 0 00.692 4.062c.545 1.428 1.355 2.48 2.41 3.124 1.18.723 3.1 1.137 5.275 1.137.983.003 1.963-.086 2.93-.266a12.248 12.248 0 003.823-1.389c.98-.567 1.86-1.288 2.61-2.136 1.252-1.418 1.998-2.997 2.553-4.4h.221c1.372 0 2.215-.549 2.68-1.009.309-.293.55-.65.707-1.046l.098-.288z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Link columns -->
      {footer.columns.map((col) => (
        <div>
          <h3 class="mb-4 font-semibold text-brand-300 text-xs uppercase tracking-wider">
            {col.heading}
          </h3>
          <ul class="space-y-2.5">
            {(col.links ? col.links : nav[col.heading.toLowerCase()]).map((link) => (
              <li>
                <a
                  href={link.href}
                  class="hover:text-white text-sm transition-colors duration-150"
                  {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex sm:flex-row flex-col justify-between items-center gap-4 pt-8 border-slate-800 border-t">
      <p class="text-sm">
        {footer.made_with}
        <a href={footer.made_by_href} class="hover:text-brand-400 transition-colors" target="_blank" rel="noopener noreferrer">
          {footer.made_by_label}
        </a>
      </p>
      <p class="text-sm">
        &ndash;
        <a href={imprint.contact.href} class="px-1 hover:text-brand-400 transition-colors">{imprint.contact.title}</a>
        &ndash;
        <a href={legal_index.href} class="px-1 hover:text-brand-400 transition-colors">{legal_index.title}</a>
        &ndash;
        <a href={imprint.impressum_page.href} class="px-1 hover:text-brand-400 transition-colors">{imprint.impressum_page.title}</a>
      </p>
    </div>
  </div>
</footer>
