---
import { footer, site } from '../data/site-data.json';
---

<footer class="bg-slate-900 text-slate-300">
  <!-- Main footer content -->
  <div class="mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8 max-w-7xl">
    <div class="gap-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 mb-12">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="group flex items-center gap-2.5 mb-4">
          <svg class="w-8 h-8" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="48" height="48" rx="10" fill="#2563EB"/>
            <path d="M24 10C16.268 10 10 16.268 10 24C10 31.732 16.268 38 24 38C27.04 38 29.856 37.024 32.136 35.368L36.586 39.818L39.414 36.99L34.964 32.54C36.944 30.184 38 27.224 38 24C38 16.268 31.732 10 24 10Z" fill="white"/>
            <path d="M24 14C18.477 14 14 18.477 14 24C14 29.523 18.477 34 24 34C26.343 34 28.511 33.228 30.258 31.93L27.428 29.1C26.46 29.676 25.268 30 24 30C20.686 30 18 27.314 18 24C18 20.686 20.686 18 24 18C27.314 18 30 20.686 30 24C30 25.268 29.676 26.46 29.1 27.428L31.93 30.258C33.228 28.511 34 26.343 34 24C34 18.477 29.523 14 24 14Z" fill="#2563EB"/>
          </svg>
          <span class="font-bold text-white text-lg tracking-tight">Scoold</span>
        </a>
        <p class="max-w-xs text-slate-400 text-sm leading-relaxed">
          {footer.tagline}
        </p>
        <!-- Social links -->
        <div class="flex items-center gap-3 mt-5">
          {footer.social.map((s) => (
            <a
              href={s.href}
              class="flex justify-center items-center bg-slate-800 hover:bg-slate-700 rounded-lg w-8 h-8 text-slate-400 hover:text-white transition-colors"
              aria-label={s.name}
              target="_blank"
              rel="noopener noreferrer"
            >
              {s.icon === 'github' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
              )}
              {s.icon === 'twitter' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              {s.icon === 'discord' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.317 4.492c-1.53-.69-3.17-1.2-4.885-1.49a.075.075 0 00-.079.036c-.21.369-.444.85-.608 1.23a18.566 18.566 0 00-5.487 0 12.36 12.36 0 00-.617-1.23A.077.077 0 008.562 3c-1.714.29-3.354.8-4.885 1.491a.07.07 0 00-.032.027C.533 9.093-.32 13.555.099 17.961a.08.08 0 00.031.055 20.03 20.03 0 005.993 2.98.078.078 0 00.084-.026c.462-.62.874-1.275 1.226-1.963.021-.04.001-.088-.041-.104a13.201 13.201 0 01-1.872-.878.075.075 0 01-.008-.125c.126-.093.252-.19.372-.287a.075.075 0 01.078-.01c3.927 1.764 8.18 1.764 12.061 0a.075.075 0 01.079.009c.12.098.245.195.372.288a.075.075 0 01-.006.125c-.598.344-1.22.635-1.873.877a.075.075 0 00-.041.105c.36.687.772 1.341 1.225 1.962a.077.077 0 00.084.028 19.963 19.963 0 006.002-2.981.076.076 0 00.032-.054c.5-5.094-.838-9.52-3.549-13.442a.06.06 0 00-.031-.028z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Link columns -->
      {footer.columns.map((col) => (
        <div>
          <h3 class="mb-4 font-semibold text-slate-400 text-xs uppercase tracking-wider">
            {col.heading}
          </h3>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-slate-400 hover:text-white text-sm transition-colors duration-150"
                  {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex sm:flex-row flex-col justify-between items-center gap-4 pt-8 border-slate-800 border-t">
      <p class="text-slate-500 text-xs">
        {footer.copyright}
      </p>
      <p class="text-slate-500 text-xs">
        {footer.made_with} <a href={footer.made_by_href} class="hover:text-slate-300 transition-colors" target="_blank" rel="noopener noreferrer">{footer.made_by_label}</a>
        ·
        <a href={site.github} class="hover:text-slate-300 transition-colors" target="_blank" rel="noopener noreferrer">{footer.open_source_label}</a>
        ·
        <a href={footer.license_href} class="hover:text-slate-300 transition-colors">{footer.license_label}</a>
      </p>
    </div>
  </div>
</footer>
