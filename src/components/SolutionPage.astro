---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from './CTA.astro';

interface Feature {
  title: string;
  description: string;
}

interface Props {
  title: string;
  subtitle: string;
  description: string;
  hero_badge: string;
  features: Feature[];
  use_cases: string[];
  cta: { label: string; href: string };
  metaDescription?: string;
}

const { title, subtitle, description, hero_badge, features, use_cases, cta, metaDescription } = Astro.props;
---

<BaseLayout title={title} description={metaDescription ?? subtitle}>
  <!-- Hero -->
  <section class="section-padding bg-white border-b border-slate-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="section-label">{hero_badge}</span>
      <h1 class="text-5xl lg:text-6xl font-extrabold text-slate-900 tracking-tight mb-5">
        {title}
      </h1>
      <p class="text-xl text-slate-500 leading-relaxed mb-4">
        {subtitle}
      </p>
      <p class="text-base text-slate-400 leading-relaxed max-w-2xl mx-auto">
        {description}
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="section-padding bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-sm font-bold uppercase tracking-widest text-brand-600 mb-8 text-center">Key capabilities</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {features.map((feature) => (
          <div class="bg-white border border-slate-100 rounded-2xl p-6">
            <div class="w-8 h-8 bg-brand-50 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-900 mb-2">{feature.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="section-padding bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-slate-900 mb-8 text-center">Common use cases</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {use_cases.map((uc) => (
          <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-xl border border-slate-100">
            <div class="w-6 h-6 rounded-full bg-brand-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-slate-700">{uc}</span>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a
          href={cta.href}
          class="inline-flex items-center gap-2 px-7 py-3.5 bg-slate-900 text-white font-semibold rounded-xl hover:bg-slate-700 transition-colors"
        >
          {cta.label}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
