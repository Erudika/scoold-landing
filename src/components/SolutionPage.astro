---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from './CTA.astro';
import { ui } from '../data/site-data.json';

interface Feature {
  title: string;
  description: string;
}

interface Props {
  title: string;
  subtitle: string;
  description: string;
  hero_badge: string;
  features: Feature[];
  use_cases: string[];
  cta: { label: string; href: string };
  metaDescription?: string;
}

const { title, subtitle, description, hero_badge, features, use_cases, cta, metaDescription } = Astro.props;
---

<BaseLayout title={title} description={metaDescription ?? subtitle}>
  <!-- Hero -->
  <section class="bg-white border-slate-100 border-b section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl text-center">
      <span class="section-label">{hero_badge}</span>
      <h1 class="mb-5 font-extrabold text-slate-900 text-5xl lg:text-6xl tracking-tight">
        {title}
      </h1>
      <p class="mb-4 text-slate-700 text-xl leading-relaxed">
        {subtitle}
      </p>
      <p class="mx-auto max-w-2xl text-slate-600 text-base leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-slate-50 section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="mb-8 font-bold text-brand-600 text-sm text-center uppercase tracking-widest">{ui.solution_page.key_capabilities_label}</h2>
      <div class="gap-6 grid sm:grid-cols-2">
        {features.map((feature) => (
          <div class="bg-white p-6 border border-slate-100 rounded-2xl">
            <div class="flex justify-center items-center bg-brand-50 mb-3 rounded-lg w-8 h-8">
              <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="mb-2 font-semibold text-slate-900">{feature.title}</h3>
            <p class="text-slate-700 text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <h2 class="mb-8 font-bold text-slate-900 text-2xl text-center">{ui.solution_page.use_cases_title}</h2>
      <div class="gap-4 grid sm:grid-cols-2">
        {use_cases.map((uc) => (
          <div class="flex items-center gap-3 bg-slate-50 p-4 border border-slate-100 rounded-xl">
            <div class="flex justify-center items-center bg-brand-100 rounded-full w-6 h-6 shrink-0">
              <svg class="w-3 h-3 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span class="font-medium text-slate-700 text-sm">{uc}</span>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a
          href={cta.href}
          class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-700 px-7 py-3.5 rounded-xl font-semibold text-white transition-colors"
        >
          {cta.label}
          &rarr;
        </a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
