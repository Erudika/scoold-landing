---
import { Image } from 'astro:assets';
import { hero, site } from '../data/site-data.json';
import herobg from '../images/herobg.svg';
import logosq from '../images/logosq.svg';
import companies from '../images/companies.png';
---
<section class="relative bg-white pt-16 lg:pt-24 pb-20 lg:pb-28 overflow-hidden" style={`background-image: url(${herobg.src});`}>
  <!-- Gradient fade edges -->
  <div class="absolute inset-0 bg-linear-to-b from-white via-transparent to-white pointer-events-none"></div>

  <div class="relative mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="items-center gap-12 lg:gap-11 grid lg:grid-cols-2 max-lg:text-center">

      <!-- Left: text content -->
      <div class="animate-fade-in">
        <!-- Badge -->
        <!-- <div class="inline-flex items-center gap-2 bg-brand-50 mb-6 px-3 py-1.5 border border-brand-100 rounded-full font-semibold text-brand-700 text-xs"> -->
        <div class="inline-flex items-center gap-2 bg-amber-50 mb-6 px-3 py-1.5 border border-amber-200 rounded-full font-semibold text-amber-800 text-xs">
          <!-- <span class="bg-brand-600 rounded-full w-1.5 h-1.5 animate-pulse"></span> -->
           <strong class="font-bold text-amber-500">❈</strong>
           <span set:html={hero.badge}></span>
        </div>

        <!-- Headline -->
        <h1 set:html={hero.title} 
          class="mb-6 font-extrabold text-slate-900 text-4xl sm:text-5xl lg:text-5xl xl:text-6xl leading-[1.05] tracking-tight">
          <!-- <span class="text-brand-500">{hero.title_highlight}</span> -->
        </h1>

        <!-- Subtitle -->
        <p class="mb-8 lg:max-w-lg text-slate-800 text-lg sm:text-xl leading-relaxed">
          {hero.subtitle}
        </p>

        <!-- CTAs -->
        <div class="lg:flex sm:flex-row max-lg:flex-col sm:items-center gap-3">
          <a
            href={hero.primary_cta.href}
            class="group inline-flex justify-center items-center gap-2 bg-slate-900 hover:bg-slate-700 mx-2 max-md:mb-2 px-6 py-3.5 rounded-xl font-semibold text-white text-sm transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            {hero.primary_cta.label}
          </a>
          <a
            href={hero.secondary_cta.href}
            class="inline-flex justify-center items-center gap-2 bg-white hover:bg-slate-50 mx-2 px-6 py-3.5 border border-slate-200 hover:border-slate-300 rounded-xl font-semibold text-slate-700 text-sm transition-all duration-200"
            target="_blank"
          >
            <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {hero.secondary_cta.label}
          </a>
        </div>

        <!-- Social proof -->
        <div class="lg:flex items-center gap-2 mt-8 text-slate-600 text-sm">
          <!-- <div class="flex -space-x-2">
            {[...Array(4)].map((_, i) => (
              <div class:list={['w-7 h-7 rounded-full border-2 border-white flex items-center justify-center text-white text-xs font-bold', ['bg-blue-500', 'bg-emerald-500', 'bg-violet-500', 'bg-orange-500'][i]]}>
                {['E', 'T', 'A', '+'][i]}
              </div>
            ))}
          </div> -->
          <span set:html={hero.social_proof}></span>
        </div>
        <div class="opacity-60 hover:opacity-100 max-lg:mx-auto xs:sm:max-w-2/3 sm:max-w-2/3 md:max-w-lg transition-all duration-300 ease-in-out">
          <Image src={companies} alt="Some of the companies using Scoold" loading="eager"/>
        </div>
      </div>

      <!-- Right: UI mockup -->
      <div class="lg:block relative max-lg:m-auto max-lg:w-[85%] xs:max-w-full sm:max-w-full lg:max-w-full animate-slide-up">
        <!-- Browser mockup frame -->
        <div class="relative bg-white shadow-2xl shadow-slate-200/60 border border-slate-200 rounded-2xl overflow-hidden">
          <!-- Browser chrome -->
          <div class="flex items-center gap-2 bg-slate-50 px-4 py-3 border-slate-200 border-b">
            <div class="flex gap-1.5">
              <div class="bg-red-400 rounded-full w-3 h-3"></div>
              <div class="bg-yellow-400 rounded-full w-3 h-3"></div>
              <div class="bg-green-400 rounded-full w-3 h-3"></div>
            </div>
            <div class="flex-1 mx-4">
              <div class="bg-white px-3 py-1 border border-slate-200 rounded-md text-slate-600 text-xs text-center">
                {hero.mockup_url}
              </div>
            </div>
          </div>

          <!-- Mock Q&A interface -->
          <div class="bg-white p-5">
            <!-- Nav bar inside mock -->
            <div class="flex justify-between items-center mb-5">
              <div class="flex items-center gap-2">
                <div class="bg-white rounded w-6 h-6">
                  <Image src={logosq} alt="Scoold Logo" loading="eager"/>
                </div>
                <div class="rounded w-32 h-4 text-xs">{hero.mockup_company}</div>
              </div>
              <div class="flex gap-2">
                <div class="bg-slate-200 rounded w-12 h-3"></div>
                <div class="bg-slate-200 rounded w-12 h-3"></div>
                <div class="justify-center bg-neutral-200 px-0.5 rounded-md w-6 h-6">
                  <svg class="fill-blue-500" width="20px" height="20px" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><path d="M16 15.503A5.041 5.041 0 1 0 16 5.42a5.041 5.041 0 0 0 0 10.083zm0 2.215c-6.703 0-11 3.699-11 5.5v3.363h22v-3.363c0-2.178-4.068-5.5-11-5.5z"></path></g></svg>
                </div>
              </div>
            </div>

            <!-- Search bar -->
            <div class="flex items-center gap-2 bg-slate-50 mb-5 px-4 py-2.5 border border-slate-200 rounded-xl">
              <svg class="w-4 h-4 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              <div class="bg-slate-200 rounded w-48 h-3"></div>
            </div>

            <!-- Questions list -->
            {hero.mockup_questions.map((q) => (
              <div class="flex gap-3 py-3 border-slate-100 last:border-0 border-b">
                <!-- Vote/answer counts -->
                <div class="flex flex-col items-center gap-1 shrink-0">
                  <div class:list={['text-center text-xs font-semibold rounded px-1.5 py-0.5', q.accepted ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600']}>
                    {q.votes}
                  </div>
                  <div class="text-slate-600 text-xs">{q.answers} {hero.mockup_answers_label}</div>
                </div>
                <!-- Question content -->
                <div class="flex-1 min-w-0">
                  <p class="mb-1.5 font-medium text-slate-800 text-xs line-clamp-1 leading-tight">{q.title}</p>
                  <div class="flex gap-1">
                    {q.tags.map((tag) => (
                      <span class="inline-block bg-brand-50 px-1.5 py-0.5 rounded font-medium text-brand-600 text-xs">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            ))}

            <!-- Ask question button -->
            <div class="mt-3">
              <div class="flex justify-center items-center bg-brand-600 opacity-90 rounded-lg w-full h-8">
                <div class="bg-white/70 rounded w-28 h-2.5"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating badge: "Enterprise Ready" -->
        <div class="-bottom-4 -left-4 absolute flex items-center gap-2.5 bg-white shadow-lg px-4 py-2.5 border border-slate-200 rounded-xl">
          <div class="flex justify-center items-center bg-emerald-100 rounded-lg w-8 h-8">
            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-slate-800 text-xs">{hero.badge_enterprise.title}</p>
            <p class="text-slate-600 text-xs">{hero.badge_enterprise.subtitle}</p>
          </div>
        </div>

        <!-- Floating badge: "Open Source" -->
        <div class="-top-4 -right-4 absolute flex items-center gap-2.5 bg-white shadow-lg px-4 py-2.5 border border-slate-200 rounded-xl">
          <div class="flex justify-center items-center bg-emerald-100 rounded-lg w-8 h-8">
            <svg class="w-4 h-4 text-emerald-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-slate-800 text-xs">{hero.badge_opensource.title}</p>
            <p class="text-slate-600 text-xs">{hero.badge_opensource.subtitle}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
