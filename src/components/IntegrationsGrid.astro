---
import { home, nav, integrations } from '@/data/site-data.json';
---

 <!-- Integrations links section -->
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="mx-auto mb-14 max-w-2xl text-center">
        <span class="section-label">{home.integrations.badge}</span>
        <h1 class="mb-4 font-extrabold text-slate-900 text-4xl lg:text-5xl tracking-tight">
          {home.integrations.title} <span class="text-brand-600">{home.integrations.title_highlight}</span>
        </h1>
        <p class="text-slate-700 text-lg leading-relaxed">
          {home.integrations.description}
        </p>
      </div>
      <div class="gap-10 grid sm:grid-cols-2">
        {nav.integrations.map((s) => (
          <a
            href={s.href}
            class="group block bg-white hover:shadow-md p-6 border border-slate-300 rounded-2xl transition-all duration-200"
          >
            <div class="inline-flex items-center gap-1.5 mb-3 py-1 font-semibold">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 256 256" class="fill-brand-600"><path d="M148.24,139.76a6,6,0,0,0-8.48,0L120,159.51,96.49,136l19.75-19.76a6,6,0,0,0-8.48-8.48L88,127.51,68.24,107.76a6,6,0,0,0-8.48,8.48L67.51,124,42.79,148.73a30,30,0,0,0,0,42.42l6.78,6.79L19.76,227.76a6,6,0,1,0,8.48,8.48l29.82-29.81,6.79,6.78a30,30,0,0,0,42.42,0L132,188.49l7.76,7.75a6,6,0,0,0,8.48-8.48L128.49,168l19.75-19.76A6,6,0,0,0,148.24,139.76Zm-49.45,65a18,18,0,0,1-25.46,0L51.27,182.67a18,18,0,0,1,0-25.46L76,132.49,123.51,180Zm137.45-185a6,6,0,0,0-8.48,0L197.94,49.57l-6.79-6.78a30,30,0,0,0-42.42,0L124,67.51l-7.76-7.75a6,6,0,0,0-8.48,8.48l80,80a6,6,0,0,0,8.48-8.48L188.49,132l24.72-24.73a30,30,0,0,0,0-42.42l-6.78-6.79,29.81-29.82A6,6,0,0,0,236.24,19.76Zm-31.51,79L180,123.51,132.49,76l24.72-24.73a18,18,0,0,1,25.46,0l22.06,22.06a18,18,0,0,1,0,25.46Z"></path></svg>
              {s.label}
            </div>
            <p class="text-slate-700 text-sm leading-relaxed">
              {integrations.filter((f) => f.title === s.label)[0]?.description}
            </p>
            <div class="flex items-center gap-1 group-hover:gap-2 mt-3 font-semibold text-brand-600 text-xs transition-all">
              {home.use_cases.learn_more_label}
              &rarr;
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>