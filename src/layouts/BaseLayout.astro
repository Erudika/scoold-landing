---
import SEOHead from "../components/SEOHead.astro";
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site, imprint } from '../data/site-data.json';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object;
  canonicalUrl?: string;
}

const {
  title,
  description = site.description,
  ogImage = '/og-default.png',
  jsonLd,
  canonicalUrl,
} = Astro.props;

const pageTitle = title
  ? `${title} - ${site.title}`
  : `${site.title} — ${site.tagline}`;

const canonical = canonicalUrl ?? new URL(Astro.url.pathname, site.url).toString();

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: site.title,
  description: site.description,
  url: site.url,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: [
    {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'EUR',
      description: 'Scoold Community - free, open source',
    },
    {
      '@type': 'Offer',
      price: '499',
      priceCurrency: 'EUR',
      description: 'Scoold Pro - one-time license',
    },
  ],
  author: {
    '@type': 'Organization',
    name: site.company,
    url: imprint.impressum.website,
  }
};
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEOHead title={pageTitle} description={description} canonical={canonical} image={ogImage} jsonLd={jsonLd ?? defaultJsonLd} />
  </head>

  <body class="bg-white min-h-screen text-base-content antialiased">
    <div class="flex flex-col min-h-screen">
      <Header />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
