---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Pagination from '@/components/Pagination.astro';
import BlogCard from '@/components/BlogCard.astro';
import { Image } from 'astro:assets';
import { blog_page, blogPage } from '../../data/site-data.json';
import { getCollection } from "astro:content";
import herobg from '../../images/herobg.svg';

const PAGE_SIZE = 15;
const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
const pagePosts = posts.slice(0, PAGE_SIZE).map((post) => ({
  // id: post.id,
  title: post.data.title,
  excerpt: post.data.excerpt,
  date: post.data.date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit"
  }),
  author: post.data.author,
  img: post.data.img,
  tags: post.data.tags,
  href: `/blog/${post.id}/`
}));
---

<BaseLayout
  title={blog_page.title_short}
  description={blog_page.description}
>
  <section class="relative bg-white border-slate-100 section-padding"  style={`background-image: url(${herobg.src});`}>
    <!-- Gradient fade edges -->
    <div class="absolute inset-0 bg-linear-to-b from-white via-transparent to-white pointer-events-none"></div>

    <div class="relative mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <span class="section-label">{blog_page.badge}</span>
      <h1 class="mb-4 font-extrabold text-slate-900 text-5xl tracking-tight">
        {blog_page.title}
      </h1>
      <p class="text-slate-700 text-xl leading-relaxed">
        {blog_page.subtitle}
      </p>
      <div class="mt-5">
        <a href="/blog/tags/" class="font-semibold text-sky-700 text-sm">{blogPage.tagsCta}</a>
      </div>
    </div>
  </section>

  <section class="mb-10">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="gap-6">
        {pagePosts.map((post) => (
          <BlogCard {...post} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
