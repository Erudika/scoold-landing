---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ComparisonsGrid from '@/components/ComparisonsGrid.astro';
import CTA from '@/components/CTA.astro';
import { home, site, components } from '@/data/site-data.json';

const { breadcrumbs } = components;
const baseUrl = site.url;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumbs.home, item: baseUrl },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/comparison/` }
  ]
};
---

<BaseLayout
  title={home.comparison.title + " " + home.comparison.title_highlight}
  description={home.comparison.description}
  jsonLd={[breadcrumbJsonLd]}
>
  <ComparisonsGrid/>
  <CTA />
</BaseLayout>
