---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SolutionsGrid from '@/components/SolutionsGrid.astro';
import CTA from '@/components/CTA.astro';
import { site, home, components } from '@/data/site-data.json';

const { breadcrumbs } = components;
const baseUrl = site.url;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumbs.home, item: baseUrl },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/solutions/` }
  ]
};
---

<BaseLayout
  title={home.use_cases.title + " " + home.use_cases.title_highlight}
  description={home.use_cases.description}
  jsonLd={[breadcrumbJsonLd]}
>
  <SolutionsGrid/>
  <CTA />
</BaseLayout>
