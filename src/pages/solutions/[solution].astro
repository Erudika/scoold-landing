---
import { site, components, solutions } from "../../data/site-data.json";
import SolutionPage from '../../components/SolutionPage.astro';

const { breadcrumbs } = components;
const baseUrl = site.url;

export async function getStaticPaths() {
    return solutions.map((solution) => ({
        params: { solution: solution.slug },
        props: { solution }
    }));
}
const { solution } = Astro.props;
const postUrl = `${baseUrl}/solutions/${solution.slug}`;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: solution.title,
  description: solution.description,
  datePublished: new Date().toISOString(),
  dateModified: new Date().toISOString(),
  author: {
    "@type": "Organization",
    name: site.company,
    url: site.companyUrl
  },
  mainEntityOfPage: postUrl,
  image: [site.companyLogo],
  url: postUrl
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumbs.home, item: baseUrl },
    { "@type": "ListItem", position: 2, name: breadcrumbs.blog, item: `${postUrl}` }
  ]
};
---

<SolutionPage {...solution}/>