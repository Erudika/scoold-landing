---
import { site, components, authors, blogPage } from "../../data/site-data.json";
import { getImage } from "astro:assets";
import SolutionPage from '../../components/SolutionPage.astro';
import { solutions } from '../../data/site-data.json';

const { breadcrumbs } = components;
const baseUrl = site.url;

const toSlug = (sol) => sol.toLowerCase().replace(/\s+/g, "-");

export async function getStaticPaths() {
  return solutions.map((sol) => ({
    params: { slug: toSlug(sol.title) },
    props: { solution: sol }
  }));
}
console.log(">>> ", Astro.props)


const { solution } = Astro.props;
const postUrl = `${baseUrl}/${toSlug(solution.title)}`;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: solution.title,
  description: solution.description,
  datePublished: new Date().toISOString(),
  dateModified: new Date().toISOString(),
  author: {
    "@type": "Organization",
    name: site.company,
    url: site.companyUrl
  },
  mainEntityOfPage: postUrl,
  image: [site.companyLogo],
  url: postUrl
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumbs.home, item: baseUrl },
    { "@type": "ListItem", position: 2, name: breadcrumbs.blog, item: `${postUrl}` }
  ]
};
---

<SolutionPage {...solution}/>