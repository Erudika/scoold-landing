---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteData from '../data/site-data.json';

const { cloud } = siteData;

const iconPaths: Record<string, string> = {
  zap: 'M13 10V3L4 14h7v7l9-11h-7z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  'trending-up': 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  globe: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
  'refresh-cw': 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  headphones: 'M3 18v-6a9 9 0 0118 0v6M3 18a3 3 0 006 0m-6 0H3m18 0a3 3 0 01-6 0m6 0h-3',
};
---

<BaseLayout
  title="Scoold Cloud"
  description="Scoold Cloud — fully managed hosted Q&A platform. All the power of Scoold Pro, deployed and managed by us."
>
  <!-- Hero -->
  <section class="section-padding bg-white border-b border-slate-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="section-label">{cloud.hero_badge}</span>
      <h1 class="text-5xl lg:text-6xl font-extrabold text-slate-900 tracking-tight mb-5">
        {cloud.title}
      </h1>
      <p class="text-xl text-slate-500 leading-relaxed mb-4">
        {cloud.subtitle}
      </p>
      <p class="text-base text-slate-400 leading-relaxed mb-8 max-w-2xl mx-auto">
        {cloud.description}
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={cloud.cloud_url}
          class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Explore Scoold Cloud
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
        <a
          href="/imprint/contact-us"
          class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-colors"
        >
          Contact sales
        </a>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="section-padding bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">
          Everything managed for you
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {cloud.features.map((feature) => (
          <div class="bg-white border border-slate-100 rounded-2xl p-6">
            <div class="w-10 h-10 bg-brand-50 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPaths[feature.icon] ?? iconPaths.zap}/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-900 mb-2">{feature.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cloud vs Self-hosted comparison -->
  <section class="section-padding bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-slate-900 text-center mb-8">Cloud vs Self-hosted</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="text-left py-3 pl-4 font-semibold text-slate-600 w-1/2">Aspect</th>
              <th class="text-center py-3 px-4 font-semibold text-brand-600">Scoold Cloud</th>
              <th class="text-center py-3 px-4 font-semibold text-slate-600">Self-hosted Pro</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {[
              ['Setup time', 'Minutes', 'Hours to days'],
              ['Infrastructure management', 'We handle it', 'You manage it'],
              ['Updates', 'Automatic', 'Manual'],
              ['Backups', 'Automatic daily', 'You configure'],
              ['Data location', 'Our cloud', 'Your infrastructure'],
              ['Cost model', 'Monthly subscription', 'One-time license'],
              ['Customization', 'Standard', 'Full control'],
            ].map((row) => (
              <tr class="hover:bg-slate-50">
                <td class="py-3 pl-4 text-slate-700 font-medium">{row[0]}</td>
                <td class="py-3 px-4 text-center text-brand-600 font-medium">{row[1]}</td>
                <td class="py-3 px-4 text-center text-slate-500">{row[2]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>
