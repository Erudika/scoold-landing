---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { Image } from 'astro:assets';
import { features_page } from '../data/site-data.json';
import herobg from '../images/herobg.svg';
import lightUI from '../images/hero-image.png';
import darkUI from '../images/hero-image-dark.png';
---

<BaseLayout
  title={features_page.title_short}
  description={features_page.description}
>
  <!-- Page hero -->
  <section class="relative bg-white border-slate-100 border-b section-padding" style={`background-image: url(${herobg.src});`}>
    <!-- Gradient fade edges -->
    <div class="absolute inset-0 bg-linear-to-b from-white via-transparent to-white pointer-events-none"></div>
    
    <div class="relative mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl text-center">
      <span class="section-label">{features_page.title_short}</span>
      <h1 class="mx-auto mb-5 max-w-3xl font-extrabold text-slate-900 text-5xl lg:text-6xl tracking-tight">
        {features_page.title}
      </h1>
      <p class="mx-auto max-w-2xl text-slate-700 text-xl leading-relaxed">
        {features_page.subtitle}
      </p>
    </div>
  </section>
  
  <section class="py-10">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 border-b border-b-gray-200 max-w-7xl">
      <h2 class="mb-8 font-bold text-5xl text-center">{features_page.themes}</h2>
      <figure class="aspect-video diff" tabindex="0">
        <div class="diff-item-1" role="img" tabindex="0">
          <div class="place-content-stretch grid">
            <Image src={lightUI} alt="Scoold UI" loading="eager"}/>
            </div>
          </div>
          <div class="diff-item-2" role="img">
            <div class="place-content-stretch grid">
              <Image src={darkUI} alt="Scoold UI" loading="eager"}/>
            </div>
          </div>
        <div class="diff-resizer"></div>
      </figure>
    </div>
  </section>

  <!-- Feature categories -->
  {features_page.categories.map((cat, catIdx) => (
    <section class:list={['section-padding', catIdx % 2 === 0 ? 'bg-white' : 'bg-slate-50']}>
      <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
        <h2 class="mb-8 font-bold text-brand-600 text-sm uppercase tracking-widest">{cat.name}</h2>
        <div class="gap-6 grid sm:grid-cols-2 lg:grid-cols-3">
          {cat.features.map((feature) => (
            <div class="flex gap-4">
              <div class="flex justify-center items-center bg-brand-50 mt-0.5 rounded-lg w-8 h-8 shrink-0">
                <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <div>
                <h3 class="mb-1 font-semibold text-slate-900 text-sm">
                  {feature.title.replace("{pro}", "")}
                  <span class={feature.title.indexOf("{pro}") > 0 ? "mx-1 badge badge-primary badge-outline badge-xs" : " hidden"}>PRO</span>
                </h3>
                <p class="text-slate-700 text-sm leading-relaxed">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <CTA />
</BaseLayout>
