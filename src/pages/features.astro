---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { features_page } from '../data/site-data.json';
---

<BaseLayout
  title="Features"
  description="Full feature breakdown of Scoold — Q&A, enterprise SSO (LDAP, SAML, SCIM), REST API, multi-space, analytics and more."
>
  <!-- Page hero -->
  <section class="bg-white border-slate-100 border-b section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl text-center">
      <span class="section-label">FEATURES</span>
      <h1 class="mx-auto mb-5 max-w-3xl font-extrabold text-slate-900 text-5xl lg:text-6xl tracking-tight">
        {features_page.title}
      </h1>
      <p class="mx-auto max-w-2xl text-slate-500 text-xl leading-relaxed">
        {features_page.subtitle}
      </p>
    </div>
  </section>

  <!-- Feature categories -->
  {features_page.categories.map((cat, catIdx) => (
    <section class:list={['section-padding', catIdx % 2 === 0 ? 'bg-white' : 'bg-slate-50']}>
      <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
        <h2 class="mb-8 font-bold text-brand-600 text-sm uppercase tracking-widest">{cat.name}</h2>
        <div class="gap-6 grid sm:grid-cols-2 lg:grid-cols-3">
          {cat.features.map((feature) => (
            <div class="flex gap-4">
              <div class="flex justify-center items-center bg-brand-50 mt-0.5 rounded-lg w-8 h-8 shrink-0">
                <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <div>
                <h3 class="mb-1 font-semibold text-slate-900 text-sm">{feature.title}</h3>
                <p class="text-slate-500 text-sm leading-relaxed">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Comparison table -->
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="mb-12 text-center">
        <h2 class="font-extrabold text-slate-900 text-3xl tracking-tight">
          {features_page.comparison.title}
        </h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-slate-200 border-b">
              {features_page.comparison.headers.map((header, i) => (
                <th
                  class:list={[
                    'py-3 font-semibold text-left',
                    i === 0 ? 'text-slate-700 pl-4 w-2/5' : 'text-center px-4',
                    i === 2 ? 'text-brand-600' : 'text-slate-600',
                  ]}
                >
                  {header}
                </th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {features_page.comparison.rows.map((row) => (
              <tr class="hover:bg-slate-50 transition-colors">
                {row.map((cell, i) => (
                  <td class:list={['py-3', i === 0 ? 'pl-4 font-medium text-slate-700' : 'text-center px-4']}>
                    {typeof cell === 'boolean' ? (
                      cell ? (
                        <svg class="mx-auto w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                      ) : (
                        <svg class="mx-auto w-5 h-5 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                      )
                    ) : (
                      <span class:list={[i === 2 ? 'text-brand-600 font-medium' : 'text-slate-600']}>{cell}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
