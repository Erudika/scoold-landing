---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Features from '../components/Features.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import siteData from '../data/site-data.json';

const { site } = siteData;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Scoold',
  description: site.description,
  url: site.url,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: [
    {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'EUR',
      description: 'Scoold Community — free, open source',
    },
    {
      '@type': 'Offer',
      price: '499',
      priceCurrency: 'EUR',
      description: 'Scoold Pro — one-time license',
    },
  ],
  author: {
    '@type': 'Organization',
    name: 'Erudika Ltd.',
    url: 'https://erudika.com',
  },
};
---

<BaseLayout
  title={undefined}
  description={site.description}
  jsonLd={jsonLd}
>
  <Hero />
  <Stats />
  <Features />

  <!-- Use cases section -->
  <section class="bg-slate-50 section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="items-center gap-16 grid lg:grid-cols-2">
        <!-- Left text -->
        <div>
          <span class="section-label">BUILT FOR TEAMS</span>
          <h2 class="mb-6 font-extrabold text-slate-900 text-4xl lg:text-5xl tracking-tight">
            We build tools that <span class="text-brand-600">empower</span> knowledge workers
          </h2>
          <p class="mb-8 text-slate-500 text-lg leading-relaxed">
            Focused on a mission to eliminate knowledge silos, we've built a platform that transforms
            how teams capture, share, and find information — without the subscription fatigue.
          </p>
          <ul class="space-y-4">
            {[
              'Deployed on your own infrastructure — your data, your rules',
              'One-time licensing. No per-seat fees, no monthly surprises',
              'Built-in search, reputation, and SSO from day one',
              'Open source core, with enterprise features in Pro',
            ].map((point) => (
              <li class="flex items-start gap-3">
                <div class="flex flex-shrink-0 justify-center items-center bg-brand-100 mt-0.5 rounded-full w-5 h-5">
                  <svg class="w-3 h-3 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-slate-600 text-sm leading-relaxed">{point}</span>
              </li>
            ))}
          </ul>
          <div class="flex gap-6 mt-10">
            {[
              { value: '10+ yrs', label: 'Open source' },
              { value: '99.9%', label: 'Uptime (Pro)' },
              { value: '24/7', label: 'Self-hosted' },
            ].map((stat) => (
              <div>
                <div class="font-extrabold text-slate-900 text-2xl">{stat.value}</div>
                <div class="font-medium text-slate-400 text-xs">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
        <!-- Right: illustration tiles -->
        <div class="gap-4 grid grid-cols-2">
          {[
            { icon: '🔍', title: 'Full-text Search', desc: 'Find any answer in seconds' },
            { icon: '🛡️', title: 'Enterprise SSO', desc: 'LDAP, SAML, SCIM ready' },
            { icon: '⭐', title: 'Reputation Engine', desc: 'Gamified knowledge sharing' },
            { icon: '🚀', title: 'Deploy Anywhere', desc: 'Docker, JAR, or cloud' },
          ].map((tile, i) => (
            <div
              class:list={[
                'p-5 rounded-2xl border transition-all duration-200 hover:shadow-md',
                i === 1 ? 'bg-brand-600 border-brand-600 text-white' : 'bg-white border-slate-100',
              ]}
            >
              <div class="mb-3 text-2xl">{tile.icon}</div>
              <h3 class:list={['text-sm font-semibold mb-1', i === 1 ? 'text-white' : 'text-slate-800']}>
                {tile.title}
              </h3>
              <p class:list={['text-xs', i === 1 ? 'text-brand-200' : 'text-slate-500']}>
                {tile.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions links section -->
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="mx-auto mb-14 max-w-2xl text-center">
        <span class="section-label">SOLUTIONS</span>
        <h2 class="mb-4 font-extrabold text-slate-900 text-4xl lg:text-5xl tracking-tight">
          One platform, <span class="text-brand-600">many use cases</span>
        </h2>
        <p class="text-slate-500 text-lg leading-relaxed">
          Whether you need a developer knowledge base, a community forum, or a customer support portal — Scoold adapts to your needs.
        </p>
      </div>
      <div class="gap-5 grid sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: 'Knowledge Base', href: '/solutions/scoold-as-knowledge-base', desc: 'Searchable institutional knowledge for your whole team.', color: 'bg-blue-50 text-blue-600 border-blue-100' },
          { title: 'Community Forum', href: '/solutions/scoold-as-community-forum', desc: 'Build a thriving community around your product or project.', color: 'bg-emerald-50 text-emerald-600 border-emerald-100' },
          { title: 'Developer Hub', href: '/solutions/scoold-as-developer-hub', desc: 'The engineering team\'s permanent home for technical Q&A.', color: 'bg-violet-50 text-violet-600 border-violet-100' },
          { title: 'Support Center', href: '/solutions/scoold-as-support-center', desc: 'Reduce ticket volume with searchable self-service answers.', color: 'bg-orange-50 text-orange-600 border-orange-100' },
          { title: 'Q&A Platform', href: '/solutions/scoold-as-questions-and-answers-platform', desc: 'Stack Overflow-style Q&A running on your own infrastructure.', color: 'bg-pink-50 text-pink-600 border-pink-100' },
          { title: 'Knowledge Sharing', href: '/solutions/scoold-as-knowledge-sharing-platform', desc: 'Break down silos and create a culture of sharing.', color: 'bg-amber-50 text-amber-600 border-amber-100' },
        ].map((s) => (
          <a
            href={s.href}
            class="group block bg-white hover:shadow-md p-6 border border-slate-100 hover:border-slate-200 rounded-2xl transition-all duration-200"
          >
            <div class:list={['inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border mb-3', s.color]}>
              {s.title}
            </div>
            <p class="text-slate-500 text-sm leading-relaxed">{s.desc}</p>
            <div class="flex items-center gap-1 group-hover:gap-2 mt-3 font-semibold text-brand-600 text-xs transition-all">
              Learn more
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Pricing />
  <FAQ limit={5} />
  <CTA />
</BaseLayout>
