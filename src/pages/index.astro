---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import HeroFeatures from '../components/HeroFeatures.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import { site, home, imprint, nav } from '../data/site-data.json';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: site.title,
  description: site.description,
  url: site.url,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: [
    {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'EUR',
      description: 'Scoold Community - free, open source',
    },
    {
      '@type': 'Offer',
      price: '499',
      priceCurrency: 'EUR',
      description: 'Scoold Pro - one-time license',
    },
  ],
  author: {
    '@type': 'Organization',
    name: site.company,
    url: imprint.impressum.website,
  },
};

const icons: Record<string, string> = {
  search: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>`,
  shield: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  rocket: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z"/>`,
  votes: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15 12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />`,
  sparkles: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />`,
  check: `<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />`
};
---

<BaseLayout
  title={undefined}
  description={site.description}
  jsonLd={jsonLd}
>
  <Hero />
  <Stats />
  <HeroFeatures />

  <!-- Mission section -->
  <section class="bg-slate-50 section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="items-center gap-16 grid lg:grid-cols-2 max-md:text-center">
        <!-- Left text -->
        <div>
          <span class="section-label">{home.mission.badge}</span>
          <h2 class="mb-6 font-extrabold text-slate-900 text-4xl lg:text-5xl tracking-tight">
            {home.mission.title} <span class="text-brand-600">{home.mission.title_highlight}</span> {home.mission.title_suffix}
          </h2>
          <p class="mb-8 text-slate-700 text-lg leading-relaxed">
            {home.mission.description}
          </p>
          <ul class="space-y-4">
            {home.mission.bullets.map((point) => (
              <li class="flex items-start gap-3">
                <div class="flex justify-center items-center bg-brand-100 mt-0.5 rounded-full w-5 h-5 shrink-0">
                  <svg class="w-3 h-3 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-slate-600 text-sm leading-relaxed">{point}</span>
              </li>
            ))}
          </ul>
          <div class="flex justify-center gap-6 mt-10">
            <ul class="timeline">
              <li>
                <div class="timeline-start timeline-box">{home.mission.stats[0].label}</div>
                <div class="timeline-end">{home.mission.stats[0].value}</div>
                <div class="timeline-middle">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="w-5 h-5"
                    set:html={icons["check"]}
                  />
                </div>
                <hr />
              </li>
              <li>
                <hr />
                <div class="timeline-middle">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="w-5 h-5"
                    set:html={icons["check"]}
                  />
                </div>
                <div class="timeline-end timeline-box">{home.mission.stats[1].label}</div>
                <div class="timeline-start">{home.mission.stats[1].value}</div>
                <hr />
              </li>
              <li>
                <hr />
                <div class="timeline-start timeline-box">{home.mission.stats[2].label}</div>
                <div class="timeline-end">{home.mission.stats[2].value}</div>
                <div class="timeline-middle">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="w-5 h-5"
                    set:html={icons["check"]}
                  />
                </div>
                <hr />
              </li>
              <li>
                <hr />
                <div class="timeline-middle">
                 <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="w-5 h-5"
                    set:html={icons["check"]}
                  />
                </div>
                <div class="timeline-end timeline-box">{home.mission.stats[3].label}</div>
                <div class="timeline-start">{home.mission.stats[3].value}</div>
                <hr />
              </li>
              <li>
                <hr />
                <div class="timeline-start timeline-box">{home.mission.stats[4].label}</div>
                <div class="timeline-end">{home.mission.stats[4].value}</div>
                <div class="timeline-middle" title="Coming soon...">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="black"
                    stroke="orange"
                    class="bg-white w-5 h-5 text-black"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </div>
              </li>
            </ul>

            <!-- {home.mission.stats.map((stat) => (
              <div>
                <div class="font-extrabold text-slate-900 text-2xl">{stat.value}</div>
                <div class="font-medium text-slate-600 text-xs">{stat.label}</div>
              </div>
            ))} -->
          </div>
        </div>
        <!-- Right: illustration tiles -->
        <div class="gap-10 grid grid-cols-2">
          {home.tiles.map((tile, i) => (
            <div class="bg-white hover:shadow-md p-10 border border-slate-300 rounded-2xl transition-all duration-200">
              <span class="inline-block bg-brand-100 mb-3 p-3 rounded text-2xl">
                <svg
                    class="w-5 h-5 text-brand-600"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    set:html={icons[tile.icon] ?? icons.zap}
                  />
              </span>
              <h3 class="mb-1 font-semibold text-slate-800 text-sm">
                {tile.title}
              </h3>
              <p class="text-slate-700 text-xs">
                {tile.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions links section -->
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="mx-auto mb-14 max-w-2xl text-center">
        <span class="section-label">{home.use_cases.badge}</span>
        <h2 class="mb-4 font-extrabold text-slate-900 text-4xl lg:text-5xl tracking-tight">
          {home.use_cases.title} <span class="text-brand-600">{home.use_cases.title_highlight}</span>
        </h2>
        <p class="text-slate-700 text-lg leading-relaxed">
          {home.use_cases.description}
        </p>
      </div>
      <div class="gap-5 grid sm:grid-cols-2 lg:grid-cols-3">
        {nav.solutions.map((s) => (
          <a
            href={s.href}
            class="group block bg-white hover:shadow-md p-6 border border-slate-300 rounded-2xl transition-all duration-200"
          >
            <div class:list={['inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border mb-3', s.color]}>
              {s.label}
            </div>
            <p class="text-slate-700 text-sm leading-relaxed">{s.desc}</p>
            <div class="flex items-center gap-1 group-hover:gap-2 mt-3 font-semibold text-brand-600 text-xs transition-all">
              {home.use_cases.learn_more_label}
              &rarr;
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FAQ limit={5} />
  <CTA />
</BaseLayout>
