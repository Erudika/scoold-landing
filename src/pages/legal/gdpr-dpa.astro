---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '@/components/Prose.astro';
import { site, components, legal, licenses_page } from '../../data/site-data.json';
import DPA from '../../data/dpa.md';
const { dpa } = legal;

const { breadcrumbs } = components;
const baseUrl = site.url;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumbs.home, item: baseUrl },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/legal/` },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/legal/gdpr-dpa/` }
  ]
};
---

<BaseLayout
  title={dpa.title}
  description={dpa.description}
  jsonLd={[breadcrumbJsonLd]}
>
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl">
      <div class="mb-10">
        <span class="section-label">
          <a href="/">{breadcrumbs.home}</a> / <a href="/legal/">{licenses_page.badge}</a>
        </span>
        <h1 class="mb-3 font-extrabold text-slate-900 text-4xl tracking-tight">{dpa.title}</h1>
        <p class="text-slate-600 text-sm">Effective date: {dpa.effective_date}</p>
      </div>
      
      <div class="space-y-8 mt-8 text-sm text-base-content/70">
        <Prose klass="prose-sm">
          <DPA/>
        </Prose>
      </div>
    </div>
  </section>
</BaseLayout>
