---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { licenses_page } from '../../data/site-data.json';
---

<BaseLayout
  title="Licenses"
  description="Scoold licensing — Apache 2.0 open source license for Scoold Community and the commercial EULA for Scoold Pro."
>
  <section class="section-padding bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <span class="section-label">{licenses_page.badge}</span>
        <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight mb-4">{licenses_page.title}</h1>
        <p class="text-slate-500 leading-relaxed">
          {licenses_page.subtitle}
        </p>
      </div>

      <!-- Tab navigation -->
      <div class="border-b border-slate-200 mb-8">
        <nav class="-mb-px flex gap-8">
          <button
            id="tab-oss"
            class="tab-btn pb-3 text-sm font-semibold border-b-2 border-brand-600 text-brand-600 transition-colors"
            data-target="panel-oss"
          >
            {licenses_page.tab_oss}
          </button>
          <button
            id="tab-pro"
            class="tab-btn pb-3 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-colors"
            data-target="panel-pro"
          >
            {licenses_page.tab_pro}
          </button>
        </nav>
      </div>

      <!-- Apache 2.0 panel -->
      <div id="panel-oss" class="tab-panel">
        <div class="bg-slate-900 rounded-2xl p-6 text-green-400 font-mono text-xs leading-relaxed overflow-x-auto">
          <p class="text-slate-400 mb-4">{licenses_page.apache.header}</p>
          <p>{licenses_page.apache.copyright}</p>
          <br/>
          <p>{licenses_page.apache.preamble}</p>
          <br/>
          <p class="text-brand-400">    {licenses_page.apache.url}</p>
          <br/>
          <p>{licenses_page.apache.disclaimer}</p>
        </div>
        <div class="mt-6 p-4 bg-brand-50 border border-brand-100 rounded-xl">
          <p class="text-sm text-brand-800">
            {licenses_page.apache.explanation}
            <a href={licenses_page.apache.explanation_link_href} class="underline" target="_blank" rel="noopener noreferrer">{licenses_page.apache.explanation_link_label}</a>.
          </p>
        </div>
      </div>

      <!-- EULA panel (hidden by default) -->
      <div id="panel-pro" class="tab-panel hidden">
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 space-y-5">
          <div>
            <h2 class="text-sm font-bold text-slate-800 uppercase tracking-wide mb-2">{licenses_page.eula.title}</h2>
            <p class="text-xs text-slate-400">{licenses_page.eula.effective_date}</p>
          </div>
          {licenses_page.eula.clauses.map((clause) => (
            <div>
              <h3 class="text-xs font-bold text-slate-700 mb-1">{clause.title}</h3>
              <p class="text-xs text-slate-500 leading-relaxed">{clause.text}</p>
            </div>
          ))}
        </div>
        <div class="mt-6 p-4 bg-amber-50 border border-amber-200 rounded-xl">
          <p class="text-sm text-amber-800">
            <strong>{licenses_page.eula.questions_cta}</strong>{' '}
            <a href={licenses_page.eula.contact_href} class="underline">{licenses_page.eula.contact_label}</a> {licenses_page.eula.before_purchasing}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetId = (tab as HTMLElement).dataset.target;
      // Update tabs
      tabs.forEach((t) => {
        t.classList.remove('border-brand-600', 'text-brand-600');
        t.classList.add('border-transparent', 'text-slate-500');
      });
      tab.classList.add('border-brand-600', 'text-brand-600');
      tab.classList.remove('border-transparent', 'text-slate-500');
      // Update panels
      document.querySelectorAll('.tab-panel').forEach((panel) => {
        panel.classList.add('hidden');
      });
      if (targetId) document.getElementById(targetId)?.classList.remove('hidden');
    });
  });
</script>
