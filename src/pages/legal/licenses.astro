---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, components, licenses_page } from '../../data/site-data.json';
import RemoteFile from '@/components/RemoteFile.astro';

const { breadcrumbs } = components;
const baseUrl = site.url;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumbs.home, item: baseUrl },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/legal/` },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/legal/licenses/` }
  ]
};
---

<BaseLayout
  title={licenses_page.title}
  description="Scoold licensing - Apache 2.0 open source license for Scoold Community and the commercial EULA for Scoold Pro."
  jsonLd={[breadcrumbJsonLd]}
>
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <div class="mb-10">
        <span class="section-label">
          <a href="/">{breadcrumbs.home}</a> / <a href="/legal/">{licenses_page.badge}</a>
        </span>
        <h1 class="mb-4 font-extrabold text-slate-900 text-4xl tracking-tight">{licenses_page.title}</h1>
        <p class="text-slate-700 leading-relaxed">
          {licenses_page.subtitle}
        </p>
      </div>
      
      <!-- Tab navigation -->
      <div id="license-tabs" class="mb-8 border-slate-200 border-b">
        <div role="tablist" class="tabs-border tabs">
          <!-- OSS tab -->
          <input type="radio" name="license_tabs" class="tab" aria-label={licenses_page.tab_oss} checked="checked"/>
          <div class="pt-3 tab-content">
            <div class="bg-slate-50 p-6 border border-slate-200 rounded-2xl overflow-x-auto font-mono text-slate-800 text-xs leading-relaxed">
              <p class="mb-4 font-bold">{licenses_page.apache.header}</p>
              <p>{licenses_page.apache.copyright}</p>
              <br/>
              <p>{licenses_page.apache.preamble}</p>
              <br/>
              <a href={licenses_page.apache.url} class="text-brand-600">{licenses_page.apache.url}</a>
              <br/>
              <br/>
              <p>{licenses_page.apache.disclaimer}</p>
            </div>
            <div class="bg-brand-50 mt-6 p-4 border border-brand-100 rounded-xl">
              <p class="text-brand-800 text-sm">
                {licenses_page.apache.explanation}
                <a href={licenses_page.apache.explanation_link_href} class="underline" target="_blank" rel="noopener noreferrer">{licenses_page.apache.explanation_link_label}</a>.
              </p>
            </div>
          </div>

          <input type="radio" name="license_tabs" class="tab" aria-label={licenses_page.tab_pro}/>
          <div class="pt-3 tab-content" id="pro">
            <div class="space-y-5 bg-slate-50 p-6 border border-slate-200 rounded-2xl font-mono text-xs">
              <div>
                <h2 class="mb-2 font-bold text-slate-800 tracking-wide">{licenses_page.eula.title}</h2>
                <p class="text-slate-600">{licenses_page.eula.effective_date}</p>
              </div>
              <RemoteFile url="https://raw.githubusercontent.com/Erudika/scoold-pro/master/LICENSE" raw="true" />
            </div>
            <div class="bg-amber-50 mt-6 p-4 border border-amber-200 rounded-xl">
              <p class="text-amber-800 text-sm">
                <strong>{licenses_page.eula.questions_cta}</strong>{' '}
                <a href={licenses_page.eula.contact_href} class="underline">{licenses_page.eula.contact_label}</a> {licenses_page.eula.before_purchasing}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
