---
import BaseLayout from '../../layouts/BaseLayout.astro';
import siteData from '../../data/site-data.json';

const { contact } = siteData.imprint;
---

<BaseLayout
  title="Contact Us"
  description="Contact the Scoold team — email, GitHub issues, or Discord. We're here to help."
>
  <section class="section-padding bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <span class="section-label">GET IN TOUCH</span>
        <h1 class="text-5xl font-extrabold text-slate-900 tracking-tight mb-4">{contact.title}</h1>
        <p class="text-xl text-slate-500 leading-relaxed">{contact.subtitle}</p>
      </div>

      <!-- Contact channels -->
      <div class="space-y-4 mb-12">
        {contact.channels.map((channel) => (
          <a
            href={channel.href}
            class="flex items-center gap-4 p-5 bg-slate-50 border border-slate-100 rounded-2xl hover:border-brand-200 hover:shadow-sm transition-all duration-200 group"
            {...(channel.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center flex-shrink-0">
              {channel.icon === 'mail' && (
                <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              )}
              {channel.icon === 'github' && (
                <svg class="w-5 h-5 text-brand-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
              )}
              {channel.icon === 'message-circle' && (
                <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              )}
            </div>
            <div>
              <div class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-0.5">{channel.label}</div>
              <div class="text-base font-medium text-slate-800 group-hover:text-brand-600 transition-colors">{channel.value}</div>
            </div>
            <svg class="w-4 h-4 text-slate-400 ml-auto group-hover:text-brand-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>

      <!-- Simple contact form placeholder -->
      <div class="bg-slate-50 border border-slate-100 rounded-2xl p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Send a message</h2>
        <form class="space-y-4" action="mailto:support@scoold.com" method="GET">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-xs font-semibold text-slate-600 mb-1.5">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Your name"
                class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
              />
            </div>
            <div>
              <label for="email" class="block text-xs font-semibold text-slate-600 mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="you@example.com"
                class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
              />
            </div>
          </div>
          <div>
            <label for="subject" class="block text-xs font-semibold text-slate-600 mb-1.5">Subject</label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="How can we help?"
              class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
            />
          </div>
          <div>
            <label for="message" class="block text-xs font-semibold text-slate-600 mb-1.5">Message</label>
            <textarea
              id="message"
              name="body"
              rows={4}
              placeholder="Tell us more about your project..."
              class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full flex items-center justify-center gap-2 px-5 py-3 bg-slate-900 text-white font-semibold rounded-xl hover:bg-slate-700 transition-colors text-sm"
          >
            Send Message
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
