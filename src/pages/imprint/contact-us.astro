---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, components, imprint } from '../../data/site-data.json';
const { contact, contact_form } = imprint;

const { breadcrumbs } = components;
const baseUrl = site.url;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumbs.home, item: baseUrl },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/imprint/` },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/imprint/contact-us/` }
  ]
};
---

<BaseLayout
  title={contact.title_short}
  description={contact.description}
  jsonLd={[breadcrumbJsonLd]}
>
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl">
      <div class="mb-10 text-center">
        <span class="section-label">{contact.badge}</span>
        <h1 class="mb-4 font-extrabold text-slate-900 text-5xl tracking-tight">{contact.title}</h1>
        <p class="text-slate-700 text-xl leading-relaxed">{contact.subtitle}</p>
      </div>

      <!-- Contact channels -->
      <div class="space-y-4 mb-12">
        {contact.channels.map((channel) => (
          <a
            href={channel.href}
            class="group flex items-center gap-4 bg-slate-50 hover:shadow-sm p-5 border border-slate-100 hover:border-brand-200 rounded-2xl transition-all duration-200"
            {...(channel.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <div class="flex justify-center items-center bg-brand-100 rounded w-10 h-10 shrink-0">
              {channel.icon === 'mail' && (
                <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              )}
              {channel.icon === 'github' && (
                <svg class="w-5 h-5 text-brand-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
              )}
              {channel.icon === 'message-circle' && (
                <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              )}
            </div>
            <div>
              <div class="mb-0.5 font-semibold text-slate-600 text-xs uppercase tracking-wider">{channel.label}</div>
              <div class="font-medium text-slate-800 group-hover:text-brand-600 text-base transition-colors">{channel.value}</div>
            </div>
            <svg class="ml-auto w-4 h-4 text-slate-600 group-hover:text-brand-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>

      <!-- Simple contact form placeholder -->
      <div class="bg-slate-50 p-6 border border-slate-100 rounded-2xl">
        <!-- Thank you message (hidden by default) -->
        <div id="thank-you-message" class="hidden py-8 text-center">
          <div class="inline-flex justify-center items-center bg-green-100 mb-4 rounded-full w-16 h-16">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h3 class="mb-2 font-bold text-slate-900 text-2xl">{contact_form.thanks}</h3>
          <p class="text-slate-600">{contact_form.thanks_msg}</p>
        </div>

        <form
          class="space-y-4"
          method="POST"
          id="contact-form"
          enctype="multipart/form-data"
          action={contact_form.form_action}
        >
          <h2 class="mb-4 font-bold text-slate-900 text-lg text-center">{contact_form.title}</h2>
          <div class="gap-4 grid sm:grid-cols-2">
            <div>
              <label for="name" class="block mb-1.5 font-semibold text-slate-600 text-xs">{contact_form.name_label}</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                minlength="2"
                maxlength="255"
                placeholder={contact_form.name_placeholder}
                class="bg-white px-4 py-2.5 border border-slate-200 focus:border-transparent rounded focus:outline-none focus:ring-2 focus:ring-brand-500 w-full text-slate-800 text-sm transition placeholder-slate-400"
                />
              </div>
              <div>
              <label for="email" class="block mb-1.5 font-semibold text-slate-600 text-xs">{contact_form.email_label}</label>
              <input
                type="email"
                id="email"
                name="email"
                maxlength="255"
                placeholder={contact_form.email_placeholder}
                class="bg-white px-4 py-2.5 border border-slate-200 focus:border-transparent rounded focus:outline-none focus:ring-2 focus:ring-brand-500 w-full text-slate-800 text-sm transition placeholder-slate-400"
                />
              </div>
            </div>
          <!-- <div>
            <label for="subject" class="block mb-1.5 font-semibold text-slate-600 text-xs">{contact_form.subject_label}</label>
            <input
            type="text"
              id="subject"
              name="subject"
              maxlength="255"
              placeholder={contact_form.subject_placeholder}
              class="bg-white px-4 py-2.5 border border-slate-200 focus:border-transparent rounded focus:outline-none focus:ring-2 focus:ring-brand-500 w-full text-slate-800 text-sm transition placeholder-slate-400"
            />
          </div> -->
          <div>
            <label for="message" class="block mb-1.5 font-semibold text-slate-600 text-xs">{contact_form.message_label}</label>
            <textarea
              id="message"
              name="message"
              required
              rows={4}
              maxlength="5000"
              placeholder={contact_form.message_placeholder}
              class="bg-white px-4 py-2.5 border border-slate-200 focus:border-transparent rounded focus:outline-none focus:ring-2 focus:ring-brand-500 w-full text-slate-800 text-sm transition resize-none placeholder-slate-400"
            ></textarea>
          </div>
          <div>
            <input name="file" type="file" class="mb-1.5 rounded w-full file-input" />
          </div>
          <button
            type="submit"
            class="flex justify-center items-center gap-2 bg-slate-900 hover:bg-slate-700 px-5 py-3 rounded w-full font-semibold text-white transition-colors"
          >
            {contact_form.submit_label}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
            </svg>
          </button>
          <div class="text-sm text-center"><a class="text-brand-700 hover:underline" href="https://erudika.com/blog/how-to-add-html-form-handling-to-your-website-for-free/" target="_blank">
            Form handling by <svg xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="16.833 25.324 550 550" class="inline-block -mr-1 w-5"><defs id="defs6"><bx:export><bx:file format="svg" href="#g10" normalization="{&quot;resetTransformOrigins&quot;:true}"/><bx:file format="svg" path="Untitled 2.svg"/></bx:export></defs><g id="g10" transform="matrix(1.333333, 0, 0, -1.333333, 14.833002, 637.476154)"><g><g transform="matrix(1.665799, 0, 0, 1.665799, -318.079294, -166.422841)" style=""><circle cx="287.519" cy="-235.59" r="17.989" transform="matrix(3.44554, 0, 0, -3.357728, -678.152608, -531.742142)" style="paint-order: stroke; stroke: rgb(255, 255, 255); fill: rgb(255, 255, 255);"/><path fill="rgb(49,199,255)" fill-rule="evenodd" d="M 405.376 233.431 C 405.376 186.627 359.442 187.788 359.442 187.788 C 359.442 187.788 359.442 148.48 359.442 148.48 C 359.442 148.48 278.303 188.732 278.303 188.732 C 278.303 188.732 225.939 179.115 225.939 233.431 C 225.939 313.666 225.939 333.723 272.743 333.723 C 277.461 329.006 279.428 325.546 279.428 325.546 C 279.428 325.546 276.538 337.747 292.802 347.246 C 311.128 357.952 339.02 357.181 360.834 346.706 C 383.94 335.613 384.435 321.242 384.435 280.28 C 406.466 273.549 405.376 271.119 405.376 233.431 Z M 305.432 290.51 C 305.432 298.195 301.594 302.04 293.925 302.04 C 293.925 302.04 281.009 302.04 281.009 302.04 C 273.335 302.04 269.5 298.195 269.5 290.51 C 269.5 290.51 269.5 277.575 269.5 277.575 C 269.5 269.888 273.335 266.046 281.009 266.046 C 281.009 266.046 293.925 266.046 293.925 266.046 C 301.594 266.046 305.432 269.888 305.432 277.575 C 305.432 277.575 305.432 290.51 305.432 290.51 Z M 305.432 240.175 C 305.432 247.86 301.594 251.705 293.925 251.705 C 293.925 251.705 281.009 251.705 281.009 251.705 C 273.335 251.705 269.5 247.86 269.5 240.175 C 269.5 240.175 269.5 227.24 269.5 227.24 C 269.5 219.552 273.335 215.713 281.009 215.713 C 281.009 215.713 293.925 215.713 293.925 215.713 C 301.594 215.713 305.432 219.552 305.432 227.24 C 305.432 227.24 305.432 240.175 305.432 240.175 Z M 355.827 290.51 C 355.827 298.195 351.989 302.04 344.316 302.04 C 344.316 302.04 331.402 302.04 331.402 302.04 C 323.729 302.04 319.891 298.195 319.891 290.51 C 319.891 290.51 319.891 277.575 319.891 277.575 C 319.891 269.888 323.729 266.046 331.402 266.046 C 331.402 266.046 344.316 266.046 344.316 266.046 C 351.989 266.046 355.827 269.888 355.827 277.575 C 355.827 277.575 355.827 290.51 355.827 290.51 Z M 355.827 240.175 C 355.827 247.86 351.989 251.705 344.316 251.705 C 344.316 251.705 331.402 251.705 331.402 251.705 C 323.729 251.705 319.891 247.86 319.891 240.175 C 319.891 240.175 319.891 227.24 319.891 227.24 C 319.891 219.552 323.729 215.713 331.402 215.713 C 331.402 215.713 344.316 215.713 344.316 215.713 C 351.989 215.713 355.827 219.552 355.827 227.24 C 355.827 227.24 355.827 240.175 355.827 240.175 Z" style="stroke-width: 1;"/></g></g></g></svg>
            Para</a>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ captchaKey: contact_form.captcha_key }}>
  // Check for ?thanks query parameter
  const urlParams = new URLSearchParams(window.location.search);
  const form = document.getElementById("contact-form");
  const thankYouMessage = document.getElementById("thank-you-message");

  if (urlParams.has('thanks')) {
    // Hide form and show thank you message
    form.style.display = 'none';
    thankYouMessage.classList.remove('hidden');
  } else {
    // Load reCAPTCHA script only if form is shown
    const script = document.createElement('script');
    script.src = `https://www.google.com/recaptcha/api.js?render=${captchaKey}`;
    script.async = true;
    script.defer = true;
    document.head.appendChild(script);

    // Handle form submission
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      grecaptcha.ready(function() {
        grecaptcha.execute(captchaKey, {action: 'submit'}).then(function(token) {
          const tokenInput = document.createElement('input');
          tokenInput.type = 'hidden';
          tokenInput.name = 'g-recaptcha-response';
          tokenInput.value = token;
          form.appendChild(tokenInput);
          form.submit();
        });
      });
    });
  }
</script>