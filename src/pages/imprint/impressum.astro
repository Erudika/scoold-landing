---
import BaseLayout from '../../layouts/BaseLayout.astro';
import siteData from '../../data/site-data.json';

const { impressum } = siteData.imprint;
---

<BaseLayout
  title="Impressum"
  description="Legal information about Erudika Ltd., the company behind Scoold."
  noindex={true}
>
  <section class="section-padding bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <span class="section-label">LEGAL</span>
        <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight mb-4">Impressum</h1>
        <p class="text-slate-500">Legal information as required under UK and EU regulations.</p>
      </div>

      <div class="prose prose-slate max-w-none">
        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-6 space-y-4">
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">Company Name</h2>
            <p class="text-slate-800 font-medium">{impressum.company}</p>
          </div>
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">Registered Address</h2>
            <p class="text-slate-800">{impressum.address}</p>
            <p class="text-slate-800">{impressum.country}</p>
          </div>
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">VAT Number</h2>
            <p class="text-slate-800">{impressum.vat}</p>
          </div>
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">Email</h2>
            <a href={`mailto:${impressum.email}`} class="text-brand-600 hover:underline">{impressum.email}</a>
          </div>
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">Website</h2>
            <a href={impressum.website} class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">
              {impressum.website}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
