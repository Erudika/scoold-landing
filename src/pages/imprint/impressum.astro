---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { imprint } from '../../data/site-data.json';
const { impressum, impressum_page } = imprint;
---

<BaseLayout
  title="Impressum"
  description="Legal information about Erudika Ltd., the company behind Scoold."
  noindex={true}
>
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl">
      <div class="mb-10">
        <span class="section-label">{impressum_page.badge}</span>
        <h1 class="mb-4 font-extrabold text-slate-900 text-4xl tracking-tight">{impressum_page.title}</h1>
        <p class="text-slate-500">{impressum_page.subtitle}</p>
      </div>

      <div class="max-w-none prose prose-slate">
        <div class="space-y-4 bg-slate-50 p-6 border border-slate-100 rounded-2xl">
          <div>
            <h2 class="mb-1 font-semibold text-slate-400 text-xs uppercase tracking-wider">{impressum_page.labels.company_name}</h2>
            <p class="font-medium text-slate-800">{impressum.company}</p>
          </div>
          <div>
            <h2 class="mb-1 font-semibold text-slate-400 text-xs uppercase tracking-wider">{impressum_page.labels.registered_address}</h2>
            <p class="text-slate-800">{impressum.address}</p>
            <p class="text-slate-800">{impressum.country}</p>
          </div>
          <div>
            <h2 class="mb-1 font-semibold text-slate-400 text-xs uppercase tracking-wider">{impressum_page.labels.vat_number}</h2>
            <p class="text-slate-800">{impressum.vat}</p>
          </div>
          <div>
            <h2 class="mb-1 font-semibold text-slate-400 text-xs uppercase tracking-wider">{impressum_page.labels.email}</h2>
            <a href={`mailto:${impressum.email}`} class="text-brand-600 hover:underline">{impressum.email}</a>
          </div>
          <div>
            <h2 class="mb-1 font-semibold text-slate-400 text-xs uppercase tracking-wider">{impressum_page.labels.website}</h2>
            <a href={impressum.website} class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">
              {impressum.website}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
