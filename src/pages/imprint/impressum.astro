---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, components, imprint, licenses_page } from '../../data/site-data.json';
import { object } from 'astro:schema';
const { impressum, impressum_page } = imprint;

const { breadcrumbs } = components;
const baseUrl = site.url;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumbs.home, item: baseUrl },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/imprint/` },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/imprint/impressum/` }
  ]
};
---

<BaseLayout
  title={impressum_page.title}
  description={impressum_page.subtitle}
  jsonLd={[breadcrumbJsonLd]}
  noindex={true}
>
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl">
      <div class="mb-10">
        <span class="section-label">
          <a href="/">{breadcrumbs.home}</a> / <a href="/legal/">{licenses_page.badge}</a>
        </span>
        <h1 class="mb-4 font-extrabold text-slate-900 text-4xl tracking-tight">{impressum_page.title}</h1>
        <p class="text-slate-700">{impressum_page.subtitle}</p>
      </div>

      <div class="max-w-none prose prose-slate">
        <div class="space-y-4 bg-slate-50 p-6 border border-slate-100 rounded-2xl">
          <div>
            <h2 class="mb-1 font-semibold text-slate-600 text-xs uppercase tracking-wider">{impressum_page.labels.company_name}</h2>
            <p class="font-medium text-slate-800">{impressum.company}</p>
          </div>
          <div>
            <h2 class="mb-1 font-semibold text-slate-600 text-xs uppercase tracking-wider">{impressum_page.labels.registered_address}</h2>
            <p class="text-slate-800">{impressum.address}</p>
            <p class="text-slate-800">{impressum.country}</p>
          </div>
          <div>
            <h2 class="mb-1 font-semibold text-slate-600 text-xs uppercase tracking-wider">{impressum_page.labels.vat_number}</h2>
            <p class="text-slate-800">{impressum.vat}</p>
          </div>
          <div>
            <h2 class="mb-1 font-semibold text-slate-600 text-xs uppercase tracking-wider">{impressum_page.labels.lar}</h2>
            <p class="text-slate-800">{impressum.lar}</p>
          </div>
          <div>
            <h2 class="mb-1 font-semibold text-slate-600 text-xs uppercase tracking-wider">{impressum_page.labels.email}</h2>
            <a href={`mailto:${impressum.email}`} class="text-brand-600 hover:underline">{impressum.email}</a>
          </div>
          <div>
            <h2 class="mb-1 font-semibold text-slate-600 text-xs uppercase tracking-wider">{impressum_page.labels.website}</h2>
            <a href={impressum.website} class="text-brand-600 hover:underline" target="_blank">
              {impressum.website}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
