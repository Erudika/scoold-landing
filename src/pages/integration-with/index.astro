---
import BaseLayout from '@/layouts/BaseLayout.astro';
import IntegrationsGrid from '@/components/IntegrationsGrid.astro';
import CTA from '@/components/CTA.astro';
import { home, site, components } from '@/data/site-data.json';

const { breadcrumbs } = components;
const baseUrl = site.url;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumbs.home, item: baseUrl },
    { "@type": "ListItem", position: 2, name: breadcrumbs.faq, item: `${baseUrl}/integration-with/` }
  ]
};
---

<BaseLayout
  title={home.integrations.title + " " + home.integrations.title_highlight}
  description={home.integrations.description}
  jsonLd={[breadcrumbJsonLd]}
>
  <IntegrationsGrid/>
  <CTA />
</BaseLayout>
