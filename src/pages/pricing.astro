---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCards from '../components/PricingCards.astro';
import CTA from '../components/CTA.astro';
import { pricing, features_page, site, components } from '../data/site-data.json';

const { breadcrumbs } = components;
const baseUrl = site.url;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pricing.pricing_faq.items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  }))
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumbs.home, item: baseUrl },
    { "@type": "ListItem", position: 2, name: breadcrumbs.pricing, item: `${baseUrl}/pricing` }
  ]
};
---

<BaseLayout
  title={pricing.title_short}
  description={pricing.description}
  jsonLd={[jsonLd, breadcrumbJsonLd]}
>
  <!-- Page hero -->
  <section class="bg-white text-center animate-fade-in section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8">
      <span class="section-label">{pricing.badge}</span>
      <h1 class="mb-4 font-extrabold text-slate-900 text-5xl lg:text-6xl tracking-tight">
        {pricing.title} <span class="text-brand-600">{pricing.title_highlight}</span>
      </h1>
      <p class="text-slate-700 text-xl leading-relaxed">
        {pricing.subtitle}
      </p>
    </div>
  </section>

  <PricingCards pageBlock={pricing} />

  <!-- Comparison table -->
  <section class="bg-white animate-fade-in section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="mb-12 text-center">
        <h2 class="font-extrabold text-slate-900 text-3xl tracking-tight">
          {features_page.comparison.title}
        </h2>
      </div>
      <div class="overflow-x-auto">
        <table class="table-zebra w-full text-sm">
          <thead>
            <tr class="border-slate-200 border-b">
              {features_page.comparison.headers.map((header, i) => (
                <th
                  class:list={[
                    'py-3 font-semibold',
                    i === 0 ? 'text-slate-600 pl-4 w-2/5 text-left' : 'px-4 text-center',
                    i === 2 ? 'text-brand-600' : 'text-slate-600 text-center',
                  ]}
                >
                  {header}
                </th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {features_page.comparison.rows.map((row) => (
              <tr class="hover:bg-slate-50 transition-colors">
                {row.map((cell, i) => (
                  <td class:list={['py-3', i === 0 ? 'pl-4 font-medium text-slate-700' : 'text-center px-4']}>
                    {typeof cell === 'boolean' ? (
                      cell ? (
                        <svg class="mx-auto w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                      ) : (
                        <svg class="mx-auto w-5 h-5 text-red-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                      )
                    ) : (
                      <span class:list={[i === 2 ? 'text-brand-600 font-bold' : 'text-slate-800 font-bold']} set:html=
                        {cell.
                          replace("{pricePro}", site.priceSign + site.pricePro).
                          replace("{priceProPlus}", site.priceSign + site.priceProPlus)} 
                      >
                      </span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Enterprise contact section -->
  <section class="bg-white py-16">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl text-center">
      <div class="bg-slate-50 p-8 border border-slate-100 rounded-2xl">
        <div class="flex justify-center items-center bg-slate-100 mx-auto mb-4 rounded-xl w-12 h-12">
          <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <h2 class="mb-2 font-bold text-slate-900 text-xl">{pricing.enterprise.title}</h2>
        <p class="mb-5 text-slate-700 text-sm">
          {pricing.enterprise.description}
        </p>
        <a
          href={pricing.enterprise.cta_href}
          class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-700 px-5 py-2.5 rounded-xl font-semibold text-white text-sm transition-colors"
        >
          {pricing.enterprise.cta_label}
          &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Pricing FAQ -->
  <section class="bg-slate-50 section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <div class="mb-12 text-center">
        <h2 class="mb-3 font-extrabold text-slate-900 text-3xl tracking-tight">{pricing.pricing_faq.title}</h2>
        <p class="text-slate-700">{pricing.pricing_faq.subtitle}</p>
      </div>
      <div class="space-y-3">
        {pricing.pricing_faq.items.map((item) => (
          <details class="group border border-slate-300 hover:border-slate-500 rounded-xl overflow-hidden">
            <summary class="flex justify-between items-center gap-4 px-5 py-4 font-medium text-slate-800 hover:text-brand-600 transition-colors cursor-pointer list-none">
              <span class="text-sm">{item.q}</span>
              <svg class="w-5 h-5 text-slate-600 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pt-1 pb-5 border-slate-100 border-t text-slate-700 text-sm leading-relaxed">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
