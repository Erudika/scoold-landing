---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { download, site } from '../data/site-data.json';

const docker = download.options[0];
const jar = download.options[1];
try {
  const githubData = await (await fetch('https://api.github.com/repos/Erudika/scoold/releases/latest')).json();
  var version = "";
  var downloadUrl = "";
  if (githubData) {
    version = githubData.tag_name ? "v" + githubData.tag_name : "";
    var downloadUrls = githubData.assets.filter((i) => i.name.endsWith(".jar"));
    if (downloadUrls.length) {
      downloadUrl = downloadUrls[0].browser_download_url;
    }
  }
} catch (error) {
  version = "";
  downloadUrl = "https://github.com/Erudika/scoold/releases"
}
---

<BaseLayout
  title={download.title_short}
  description={download.description}
>
  <!-- Hero -->
  <section class="bg-white border-slate-100 section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl text-center">
      <span class="section-label">{download.hero_badge}</span>
      <h1 class="mb-5 font-extrabold text-slate-900 text-5xl lg:text-6xl tracking-tight">
        {download.title}
      </h1>
      <p class="text-slate-700 text-xl leading-relaxed">
        {download.subtitle}
      </p>
    </div>
  </section>

  <!-- Download options -->
  <section class="bg-slate-50 section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="gap-6 grid md:grid-cols-2">
        <!-- JAR file -->
        <div class="bg-white shadow-sm p-6 border border-slate-200 rounded-2xl">
          <div class="flex justify-center items-center bg-brand-50 mb-4 rounded-xl w-10 h-10">
              <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
          </div>
          <h3 class="mb-2 font-semibold text-slate-900">{jar.title}</h3>
          <p class="mb-4 text-slate-700 text-sm leading-relaxed">{jar.description}</p>
            <div class="grid md:grid-rows-2">
              <a id="downloadUrl"
                href={downloadUrl}
                class="inline-flex justify-center items-center gap-2 bg-brand-600 hover:bg-brand-500 px-7 py-3.5 rounded-xl font-semibold text-white text-sm transition-all duration-200"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                </svg>
                Download Scoold <span id="downloadVer">{version}</span>
              </a>
              <span class="mt-3 text-center">
                <a
                  href={jar.href}
                  class="inline-flex items-center gap-2 font-medium text-brand-600 hover:text-brand-700 text-sm transition-colors"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {download.view_releases_label}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              </span>
            </div>
        </div>
        <!-- Docker -->
        <div class="bg-white shadow-sm p-6 border border-slate-200 rounded-2xl">
          <div class="flex justify-center items-center bg-brand-50 mb-4 rounded-xl w-10 h-10">
              <svg class="w-5 h-5 text-brand-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M13.983 11.078h2.119a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.119a.185.185 0 00-.185.185v1.888c0 .102.083.185.185.185m-2.954-5.43h2.118a.186.186 0 00.186-.186V3.574a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.186m0 2.716h2.118a.187.187 0 00.186-.186V6.29a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.887c0 .102.082.185.185.186m-2.93 0h2.12a.186.186 0 00.184-.186V6.29a.185.185 0 00-.185-.185H8.1a.185.185 0 00-.185.185v1.887c0 .102.083.185.185.186m-2.964 0h2.119a.186.186 0 00.185-.186V6.29a.185.185 0 00-.185-.185H5.136a.186.186 0 00-.186.185v1.887c0 .102.084.185.186.186m5.893 2.715h2.118a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.185m-2.93 0h2.12a.185.185 0 00.184-.185V9.006a.185.185 0 00-.184-.186h-2.12a.185.185 0 00-.184.185v1.888c0 .102.083.185.185.185m-2.964 0h2.119a.185.185 0 00.185-.185V9.006a.185.185 0 00-.184-.186h-2.12a.186.186 0 00-.186.186v1.887c0 .102.084.185.186.185m-2.92 0h2.12a.186.186 0 00.184-.185V9.006a.185.185 0 00-.184-.186h-2.12a.185.185 0 00-.184.186v1.887c0 .102.082.185.185.185M23.763 9.89c-.065-.051-.672-.51-1.954-.51-.338.001-.676.03-1.01.087-.248-1.7-1.653-2.53-1.716-2.566l-.344-.199-.226.327c-.284.438-.49.922-.612 1.43-.23.97-.09 1.882.403 2.661-.595.332-1.55.413-1.744.42H.751a.751.751 0 00-.75.748 11.376 11.376 0 00.692 4.062c.545 1.428 1.355 2.48 2.41 3.124 1.18.723 3.1 1.137 5.275 1.137.983.003 1.963-.086 2.93-.266a12.248 12.248 0 003.823-1.389c.98-.567 1.86-1.288 2.61-2.136 1.252-1.418 1.998-2.997 2.553-4.4h.221c1.372 0 2.215-.549 2.68-1.009.309-.293.55-.65.707-1.046l.098-.288z"/>
              </svg>
          </div>
          <h3 class="mb-2 font-semibold text-slate-900">{docker.title}</h3>
          <p class="mb-4 text-slate-700 text-sm leading-relaxed">{docker.description}</p>
            <div class="bg-slate-900 px-4 py-3 rounded-lg font-mono text-white text-sm break-all">
              {docker.command}
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- System requirements -->
  <section class="bg-white section-padding">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <h2 class="mb-6 font-bold text-slate-900 text-2xl">{download.requirements_title}</h2>
      <ul class="space-y-3">
        {download.requirements.map((req) => (
          <li class="flex items-center gap-3 text-slate-600 text-sm">
            <svg class="w-4 h-4 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
            {req}
          </li>
        ))}
      </ul>
      <div class="bg-brand-50 mt-8 p-5 border border-brand-100 rounded-xl">
        <p class="text-brand-800 text-sm">
          <strong>{download.docs_cta}</strong>{' '}
          <a href={download.docs_href} class="font-medium underline hover:no-underline">
            {download.docs_link_label}
          </a>  
        </p>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>

<script>
  try {
    var versionEl = document.getElementById("downloadVer");
    var downloadUrlEl = document.getElementById("downloadUrl");
    var dlTimestamp = window.localStorage.getItem("scoold-dl-timestamp");
    if (!dlTimestamp || new Date().getTime() > (Number.parseInt(dlTimestamp) + 6*60*60*1000)) {
      const githubData = await (await fetch('https://api.github.com/repos/Erudika/scoold/releases/latest')).json();
      if (githubData) {
        var latestVer = githubData.tag_name ? "v" + githubData.tag_name : "";
        var downloadUrls = githubData.assets.filter((i) => i.name.endsWith(".jar"));
        if (downloadUrls.length) {
          var downloadUrl = downloadUrls[0].browser_download_url;
          if (versionEl && downloadUrlEl && versionEl.textContent !== latestVer) {
            downloadUrlEl.setAttribute("href", downloadUrl);
            versionEl.textContent = latestVer;
          }
        }
        window.localStorage.setItem("scoold-dl-timestamp", new Date().getTime().toString());
      }
    }
  } catch (error) {
  }
</script>